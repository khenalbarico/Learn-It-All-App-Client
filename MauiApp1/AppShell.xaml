<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiApp1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Learn It All">

    <TabBar>
        <ShellContent x:Name="HomeTab"      Title="Home"       Route="home"/>
        <ShellContent x:Name="LibraryTab"   Title="Library"    Route="library"/>
        <ShellContent x:Name="MyLibraryTab" Title="My Library" Route="mylibrary"/>
        <ShellContent x:Name="AccountTab"   Title="Account"    Route="account"/>
    </TabBar>

</Shell>
