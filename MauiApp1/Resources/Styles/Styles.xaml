<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══════════════════════════════════════════════
         SHELL & NAVIGATION
    ═══════════════════════════════════════════════ -->

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"      Value="{StaticResource AppNavy}"/>
        <Setter Property="Shell.ForegroundColor"      Value="{StaticResource AppTextOnDark}"/>
        <Setter Property="Shell.TitleColor"           Value="{StaticResource AppTextOnDark}"/>
        <Setter Property="Shell.DisabledColor"        Value="{StaticResource AppTextMuted}"/>
        <Setter Property="Shell.UnselectedColor"      Value="{StaticResource AppTextMuted}"/>
        <Setter Property="Shell.NavBarHasShadow"      Value="False"/>
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource AppSurface}"/>
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource AppOrange}"/>
        <Setter Property="Shell.TabBarTitleColor"      Value="{StaticResource AppOrange}"/>
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource AppTextMuted}"/>
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="BackgroundColor"  Value="{StaticResource AppBackground}"/>
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource AppNavy}"/>
        <Setter Property="BarTextColor"       Value="{StaticResource AppTextOnDark}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         BUTTONS
    ═══════════════════════════════════════════════ -->

    <Style TargetType="Button">
        <Setter Property="TextColor"          Value="{StaticResource AppTextOnDark}"/>
        <Setter Property="BackgroundColor"    Value="{StaticResource AppNavy}"/>
        <Setter Property="FontFamily"         Value="OpenSansSemibold"/>
        <Setter Property="FontSize"           Value="15"/>
        <Setter Property="CornerRadius"       Value="10"/>
        <Setter Property="Padding"            Value="16,12"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor"       Value="{StaticResource AppTextMuted}"/>
                            <Setter Property="BackgroundColor" Value="{StaticResource AppDivider}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver"/>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="TextColor"            Value="White"/>
        <Setter Property="BackgroundColor"      Value="{StaticResource AppOrange}"/>
        <Setter Property="FontFamily"           Value="OpenSansSemibold"/>
        <Setter Property="FontSize"             Value="15"/>
        <Setter Property="CornerRadius"         Value="10"/>
        <Setter Property="Padding"              Value="16,14"/>
        <Setter Property="MinimumHeightRequest" Value="52"/>
        <Setter Property="HorizontalOptions"    Value="Fill"/>
    </Style>

    <Style x:Key="SmallPrimaryButtonStyle" TargetType="Button">
        <Setter Property="TextColor"            Value="White"/>
        <Setter Property="BackgroundColor"      Value="{StaticResource AppOrange}"/>
        <Setter Property="FontFamily"           Value="OpenSansSemibold"/>
        <Setter Property="FontSize"             Value="12"/>
        <Setter Property="CornerRadius"         Value="8"/>
        <Setter Property="Padding"              Value="8,6"/>
        <Setter Property="MinimumHeightRequest" Value="36"/>
        <Setter Property="HorizontalOptions"    Value="Fill"/>
    </Style>

    <Style x:Key="OutlineButtonStyle" TargetType="Button">
        <Setter Property="TextColor"            Value="{StaticResource AppNavy}"/>
        <Setter Property="BackgroundColor"      Value="Transparent"/>
        <Setter Property="BorderColor"          Value="{StaticResource AppNavy}"/>
        <Setter Property="BorderWidth"          Value="1.5"/>
        <Setter Property="FontFamily"           Value="OpenSansSemibold"/>
        <Setter Property="FontSize"             Value="15"/>
        <Setter Property="CornerRadius"         Value="10"/>
        <Setter Property="Padding"              Value="16,14"/>
        <Setter Property="MinimumHeightRequest" Value="52"/>
        <Setter Property="HorizontalOptions"    Value="Fill"/>
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="TextColor"         Value="{StaticResource AppNavy}"/>
        <Setter Property="BackgroundColor"   Value="Transparent"/>
        <Setter Property="BorderWidth"       Value="0"/>
        <Setter Property="FontFamily"        Value="OpenSansRegular"/>
        <Setter Property="FontSize"          Value="14"/>
        <Setter Property="CornerRadius"      Value="0"/>
        <Setter Property="Padding"           Value="8,4"/>
        <Setter Property="MinimumHeightRequest" Value="40"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         CARDS & BORDERS
    ═══════════════════════════════════════════════ -->

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="BackgroundColor"  Value="{StaticResource AppSurface}"/>
        <Setter Property="StrokeShape"      Value="RoundRectangle 12"/>
        <Setter Property="Stroke"           Value="{StaticResource AppDivider}"/>
        <Setter Property="StrokeThickness"  Value="1"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource AppNavyBrush}" Offset="0,2" Radius="8" Opacity="0.07"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EntryBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor"  Value="{StaticResource AppSurface}"/>
        <Setter Property="StrokeShape"      Value="RoundRectangle 10"/>
        <Setter Property="Stroke"           Value="{StaticResource AppDivider}"/>
        <Setter Property="StrokeThickness"  Value="1.5"/>
        <Setter Property="Padding"          Value="14,4"/>
        <Setter Property="MinimumHeightRequest" Value="54"/>
    </Style>

    <Style x:Key="GlassEntryBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor"      Value="#FFFFFF"/>
        <Setter Property="StrokeShape"          Value="RoundRectangle 14"/>
        <Setter Property="Stroke"               Value="#DDE4F0"/>
        <Setter Property="StrokeThickness"      Value="1.5"/>
        <Setter Property="Padding"              Value="18,4"/>
        <Setter Property="MinimumHeightRequest" Value="58"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource AppNavyBrush}" Offset="0,2" Radius="8" Opacity="0.06"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke"          Value="{StaticResource AppDivider}"/>
        <Setter Property="StrokeShape"     Value="Rectangle"/>
        <Setter Property="StrokeThickness" Value="1"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         LABELS / TEXT
    ═══════════════════════════════════════════════ -->

    <Style TargetType="Label">
        <Setter Property="TextColor"      Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily"     Value="OpenSansRegular"/>
        <Setter Property="FontSize"       Value="14"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource AppTextMuted}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="TextColor"             Value="{StaticResource AppNavy}"/>
        <Setter Property="FontFamily"            Value="OpenSansSemibold"/>
        <Setter Property="FontSize"              Value="26"/>
        <Setter Property="HorizontalOptions"     Value="Start"/>
        <Setter Property="HorizontalTextAlignment" Value="Start"/>
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="TextColor"   Value="{StaticResource AppNavy}"/>
        <Setter Property="FontFamily"  Value="OpenSansSemibold"/>
        <Setter Property="FontSize"    Value="16"/>
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="Label">
        <Setter Property="TextColor"  Value="{StaticResource AppTextSecondary}"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize"   Value="14"/>
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="Label">
        <Setter Property="TextColor"  Value="{StaticResource AppTextMuted}"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize"   Value="13"/>
    </Style>

    <Style x:Key="ErrorTextStyle" TargetType="Label">
        <Setter Property="TextColor"             Value="{StaticResource AppError}"/>
        <Setter Property="FontFamily"            Value="OpenSansRegular"/>
        <Setter Property="FontSize"              Value="13"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="OnDarkLabelStyle" TargetType="Label">
        <Setter Property="TextColor"  Value="{StaticResource AppTextOnDark}"/>
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
        <Setter Property="FontSize"   Value="14"/>
    </Style>

    <Style x:Key="OnDarkTitleStyle" TargetType="Label">
        <Setter Property="TextColor"  Value="{StaticResource AppTextOnDark}"/>
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize"   Value="24"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <!-- Legacy named styles -->
    <Style x:Key="Headline" TargetType="Label">
        <Setter Property="TextColor"             Value="{StaticResource AppNavy}"/>
        <Setter Property="FontFamily"            Value="OpenSansSemibold"/>
        <Setter Property="FontSize"              Value="28"/>
        <Setter Property="HorizontalOptions"     Value="Center"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SubHeadline" TargetType="Label">
        <Setter Property="TextColor"             Value="{StaticResource AppTextSecondary}"/>
        <Setter Property="FontFamily"            Value="OpenSansRegular"/>
        <Setter Property="FontSize"              Value="16"/>
        <Setter Property="HorizontalOptions"     Value="Center"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════════
         FORM CONTROLS
    ═══════════════════════════════════════════════ -->

    <Style TargetType="Entry">
        <Setter Property="TextColor"          Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="BackgroundColor"    Value="Transparent"/>
        <Setter Property="FontFamily"         Value="OpenSansRegular"/>
        <Setter Property="FontSize"           Value="15"/>
        <Setter Property="PlaceholderColor"   Value="{StaticResource AppTextMuted}"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal"/>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{StaticResource AppTextMuted}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor"        Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource AppTextMuted}"/>
        <Setter Property="CancelButtonColor" Value="{StaticResource AppTextSecondary}"/>
        <Setter Property="BackgroundColor"  Value="{StaticResource AppSurface}"/>
        <Setter Property="FontFamily"       Value="OpenSansRegular"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource AppOrange}"/>
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource AppOrange}"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color"                Value="{StaticResource AppNavy}"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor"    Value="{StaticResource AppOrange}"/>
        <Setter Property="ThumbColor" Value="{StaticResource White}"/>
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinimumTrackColor" Value="{StaticResource AppOrange}"/>
        <Setter Property="MaximumTrackColor" Value="{StaticResource AppDivider}"/>
        <Setter Property="ThumbColor"        Value="{StaticResource AppNavy}"/>
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource AppOrange}"/>
    </Style>

    <Style TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource AppDivider}"/>
    </Style>

    <Style TargetType="ImageButton">
        <Setter Property="Opacity"          Value="1"/>
        <Setter Property="BorderColor"      Value="Transparent"/>
        <Setter Property="BorderWidth"      Value="0"/>
        <Setter Property="CornerRadius"     Value="0"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
    </Style>

    <Style TargetType="Shadow">
        <Setter Property="Radius"  Value="12"/>
        <Setter Property="Opacity" Value="0.08"/>
        <Setter Property="Brush"   Value="{StaticResource AppNavyBrush}"/>
        <Setter Property="Offset"  Value="0,2"/>
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor"          Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="BackgroundColor"    Value="Transparent"/>
        <Setter Property="FontFamily"         Value="OpenSansRegular"/>
        <Setter Property="FontSize"           Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor"          Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="BackgroundColor"    Value="Transparent"/>
        <Setter Property="FontFamily"         Value="OpenSansRegular"/>
        <Setter Property="FontSize"           Value="14"/>
        <Setter Property="PlaceholderColor"   Value="{StaticResource AppTextMuted}"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor"          Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="TitleColor"         Value="{StaticResource AppTextMuted}"/>
        <Setter Property="BackgroundColor"    Value="Transparent"/>
        <Setter Property="FontFamily"         Value="OpenSansRegular"/>
        <Setter Property="FontSize"           Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="BackgroundColor"    Value="Transparent"/>
        <Setter Property="TextColor"          Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="FontFamily"         Value="OpenSansRegular"/>
        <Setter Property="FontSize"           Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
    </Style>

    <Style TargetType="SwipeItem">
        <Setter Property="BackgroundColor" Value="{StaticResource AppSurface}"/>
    </Style>

    <Style TargetType="SearchHandler">
        <Setter Property="TextColor"        Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource AppTextMuted}"/>
        <Setter Property="BackgroundColor"  Value="Transparent"/>
        <Setter Property="FontFamily"       Value="OpenSansRegular"/>
        <Setter Property="FontSize"         Value="14"/>
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="TextColor"       Value="{StaticResource AppTextPrimary}"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontFamily"      Value="OpenSansRegular"/>
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="MinimumHeightRequest" Value="44"/>
        <Setter Property="MinimumWidthRequest"  Value="44"/>
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource AppSurface}"/>
        <Setter Property="BarTextColor"       Value="{StaticResource AppOrange}"/>
        <Setter Property="UnselectedTabColor" Value="{StaticResource AppTextMuted}"/>
        <Setter Property="SelectedTabColor"   Value="{StaticResource AppOrange}"/>
    </Style>

</ResourceDictionary>
