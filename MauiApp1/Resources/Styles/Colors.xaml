<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Primary Brand Colors (Orange-Dominant Student Theme) ── -->
    <Color x:Key="AppNavy">#C2410C</Color>        <!-- Deep orange (primary) -->
    <Color x:Key="AppNavyLight">#EA580C</Color>   <!-- Vibrant orange -->
    <Color x:Key="AppBlue">#1E40AF</Color>         <!-- Rich blue (minor accent) -->
    <Color x:Key="AppOrange">#F97316</Color>       <!-- Bright CTA orange -->
    <Color x:Key="AppOrangeDark">#C2410C</Color>  <!-- Dark orange -->

    <!-- Backgrounds -->
    <Color x:Key="AppBackground">#FFFBF8</Color>       <!-- Warm cream -->
    <Color x:Key="AppSurface">#FFFFFF</Color>
    <Color x:Key="AppSurfaceVariant">#FFF4ED</Color>   <!-- Orange-50 tint -->

    <!-- Text -->
    <Color x:Key="AppTextPrimary">#1C0A00</Color>      <!-- Very dark warm -->
    <Color x:Key="AppTextSecondary">#6B4F3A</Color>    <!-- Warm brown-gray -->
    <Color x:Key="AppTextMuted">#A88B7A</Color>        <!-- Warm muted -->
    <Color x:Key="AppTextOnDark">#FFFFFF</Color>

    <!-- UI Elements -->
    <Color x:Key="AppDivider">#FDDDB8</Color>          <!-- Warm orange divider -->
    <Color x:Key="AppError">#EF4444</Color>
    <Color x:Key="AppSuccess">#10B981</Color>

    <!-- Legacy keys kept for MAUI framework defaults -->
    <Color x:Key="Primary">#C2410C</Color>
    <Color x:Key="PrimaryDark">#EA580C</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#F97316</Color>
    <Color x:Key="SecondaryDarkText">#1C0A00</Color>
    <Color x:Key="Tertiary">#1E40AF</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#F97316</Color>
    <Color x:Key="MidnightBlue">#1C0A00</Color>
    <Color x:Key="OffBlack">#0A0400</Color>
    <Color x:Key="Gray100">#FFFBF8</Color>
    <Color x:Key="Gray200">#FDDDB8</Color>
    <Color x:Key="Gray300">#FBB879</Color>
    <Color x:Key="Gray400">#A88B7A</Color>
    <Color x:Key="Gray500">#6B4F3A</Color>
    <Color x:Key="Gray600">#4A3020</Color>
    <Color x:Key="Gray900">#1C0A00</Color>
    <Color x:Key="Gray950">#0A0400</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppNavyBrush"      Color="{StaticResource AppNavy}"/>
    <SolidColorBrush x:Key="AppBlueBrush"       Color="{StaticResource AppBlue}"/>
    <SolidColorBrush x:Key="AppOrangeBrush"     Color="{StaticResource AppOrange}"/>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
    <SolidColorBrush x:Key="AppSurfaceBrush"    Color="{StaticResource AppSurface}"/>
    <SolidColorBrush x:Key="AppDividerBrush"    Color="{StaticResource AppDivider}"/>
    <SolidColorBrush x:Key="PrimaryBrush"       Color="{StaticResource AppNavy}"/>
    <SolidColorBrush x:Key="SecondaryBrush"     Color="{StaticResource AppOrange}"/>
    <SolidColorBrush x:Key="TertiaryBrush"      Color="{StaticResource AppBlue}"/>
    <SolidColorBrush x:Key="WhiteBrush"         Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"         Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush"       Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"       Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"       Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"       Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"       Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"       Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"       Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"       Color="{StaticResource Gray950}"/>

</ResourceDictionary>
