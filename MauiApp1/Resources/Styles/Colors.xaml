<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand Colors (derived from app logo) -->
    <Color x:Key="AppNavy">#1B3A6B</Color>
    <Color x:Key="AppNavyLight">#2A5298</Color>
    <Color x:Key="AppBlue">#2E7BC4</Color>
    <Color x:Key="AppOrange">#F5A623</Color>
    <Color x:Key="AppOrangeDark">#D4891A</Color>

    <!-- Backgrounds -->
    <Color x:Key="AppBackground">#F4F7FB</Color>
    <Color x:Key="AppSurface">#FFFFFF</Color>
    <Color x:Key="AppSurfaceVariant">#EEF2F8</Color>

    <!-- Text -->
    <Color x:Key="AppTextPrimary">#1B2B45</Color>
    <Color x:Key="AppTextSecondary">#6B7A8D</Color>
    <Color x:Key="AppTextMuted">#A8B4C5</Color>
    <Color x:Key="AppTextOnDark">#FFFFFF</Color>

    <!-- UI Elements -->
    <Color x:Key="AppDivider">#E5EAF2</Color>
    <Color x:Key="AppError">#E53E3E</Color>
    <Color x:Key="AppSuccess">#38A169</Color>

    <!-- Legacy keys kept for MAUI framework defaults -->
    <Color x:Key="Primary">#1B3A6B</Color>
    <Color x:Key="PrimaryDark">#2A5298</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#F5A623</Color>
    <Color x:Key="SecondaryDarkText">#1B3A6B</Color>
    <Color x:Key="Tertiary">#2E7BC4</Color>
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#F5A623</Color>
    <Color x:Key="MidnightBlue">#1B3A6B</Color>
    <Color x:Key="OffBlack">#0D1B2A</Color>
    <Color x:Key="Gray100">#F4F7FB</Color>
    <Color x:Key="Gray200">#E5EAF2</Color>
    <Color x:Key="Gray300">#C8D0DC</Color>
    <Color x:Key="Gray400">#A8B4C5</Color>
    <Color x:Key="Gray500">#6B7A8D</Color>
    <Color x:Key="Gray600">#3D4E63</Color>
    <Color x:Key="Gray900">#1B2B45</Color>
    <Color x:Key="Gray950">#0D1622</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppNavyBrush"      Color="{StaticResource AppNavy}"/>
    <SolidColorBrush x:Key="AppBlueBrush"       Color="{StaticResource AppBlue}"/>
    <SolidColorBrush x:Key="AppOrangeBrush"     Color="{StaticResource AppOrange}"/>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
    <SolidColorBrush x:Key="AppSurfaceBrush"    Color="{StaticResource AppSurface}"/>
    <SolidColorBrush x:Key="AppDividerBrush"    Color="{StaticResource AppDivider}"/>
    <SolidColorBrush x:Key="PrimaryBrush"       Color="{StaticResource AppNavy}"/>
    <SolidColorBrush x:Key="SecondaryBrush"     Color="{StaticResource AppOrange}"/>
    <SolidColorBrush x:Key="TertiaryBrush"      Color="{StaticResource AppBlue}"/>
    <SolidColorBrush x:Key="WhiteBrush"         Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"         Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush"       Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"       Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"       Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"       Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"       Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"       Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"       Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"       Color="{StaticResource Gray950}"/>

</ResourceDictionary>