<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:HomeViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ── Hero header (gradient + orb) ───────────────────── -->
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                        <GradientStop Color="#0D1830" Offset="0.0"/>
                        <GradientStop Color="#1A3660" Offset="0.5"/>
                        <GradientStop Color="#2A5298" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- Decorative orb — top right -->
                <Border
                    HeightRequest="200" WidthRequest="200"
                    StrokeShape="Ellipse"
                    Stroke="Transparent" StrokeThickness="0"
                    HorizontalOptions="End" VerticalOptions="Start"
                    Margin="0,-60,-80,0"
                    InputTransparent="True">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                            <GradientStop Color="#403A78D0" Offset="0.0"/>
                            <GradientStop Color="#002A5298" Offset="1.0"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Decorative orb — bottom left (amber) -->
                <Border
                    HeightRequest="140" WidthRequest="140"
                    StrokeShape="Ellipse"
                    Stroke="Transparent" StrokeThickness="0"
                    HorizontalOptions="Start" VerticalOptions="End"
                    Margin="-60,0,0,-40"
                    InputTransparent="True">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                            <GradientStop Color="#38F5A623" Offset="0.0"/>
                            <GradientStop Color="#00F5A623" Offset="1.0"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Hero content -->
                <VerticalStackLayout Spacing="6" Padding="24,56,24,36">
                    <Image
                        Source="app_logo.png"
                        HeightRequest="52"
                        WidthRequest="52"
                        Aspect="AspectFit"
                        HorizontalOptions="Start"
                        Margin="0,0,0,10"/>
                    <Label
                        Text="Learn It All"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="30"/>
                    <Label
                        Text="Your knowledge library, anytime."
                        TextColor="White"
                        FontFamily="OpenSansRegular"
                        FontSize="14"
                        Opacity="0.7"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ── Guest sign-in prompt ───────────────────────────── -->
            <Border
                IsVisible="{Binding IsGuest}"
                StrokeShape="Rectangle"
                Stroke="Transparent"
                StrokeThickness="0"
                Padding="20,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#D4890F" Offset="0.0"/>
                        <GradientStop Color="#F5A623" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        Text="Sign in to access your full library"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="13"
                        VerticalOptions="Center"/>
                    <Label
                        Grid.Column="1"
                        Text="›"
                        TextColor="White"
                        FontSize="22"
                        VerticalOptions="Center"/>
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSignInBannerTapped"/>
                </Border.GestureRecognizers>
            </Border>

            <!-- ── Quick actions ──────────────────────────────────── -->
            <VerticalStackLayout Padding="20,24,20,8" Spacing="12">

                <Label
                    Text="EXPLORE"
                    Style="{StaticResource MutedTextStyle}"
                    FontFamily="OpenSansSemibold"
                    FontSize="11"
                    CharacterSpacing="1.2"
                    Margin="0,0,0,4"/>

                <!-- Browse Library card -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,16">

                        <!-- Icon: gradient box -->
                        <Border
                            Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            HeightRequest="48"
                            WidthRequest="48">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A3660" Offset="0"/>
                                    <GradientStop Color="#2E7BC4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label
                                Text="B"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label Text="Browse Library" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource AppTextPrimary}"/>
                            <Label Text="Discover books to learn from" Style="{StaticResource MutedTextStyle}" FontSize="12"/>
                        </VerticalStackLayout>
                        <Label
                            Grid.Column="2"
                            Text="›"
                            FontSize="24"
                            TextColor="{StaticResource AppTextMuted}"
                            VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BrowseLibraryCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- My Library card -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,16">

                        <!-- Icon: orange gradient box -->
                        <Border
                            Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            HeightRequest="48"
                            WidthRequest="48">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#D4890F" Offset="0"/>
                                    <GradientStop Color="#F5A623" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label
                                Text="M"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label Text="My Library" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource AppTextPrimary}"/>
                            <Label Text="Your purchased books" Style="{StaticResource MutedTextStyle}" FontSize="12"/>
                        </VerticalStackLayout>
                        <Label
                            Grid.Column="2"
                            Text="›"
                            FontSize="24"
                            TextColor="{StaticResource AppTextMuted}"
                            VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MyLibraryCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>

            <!-- ── Coming soon section ────────────────────────────── -->
            <VerticalStackLayout Padding="20,8,20,40" Spacing="12">

                <Label
                    Text="COMING SOON"
                    Style="{StaticResource MutedTextStyle}"
                    FontFamily="OpenSansSemibold"
                    FontSize="11"
                    CharacterSpacing="1.2"
                    Margin="0,0,0,4"/>

                <Border
                    BackgroundColor="{StaticResource AppSurface}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{StaticResource AppDivider}"
                    StrokeThickness="1"
                    Padding="0">
                    <Grid ColumnDefinitions="5,*" ColumnSpacing="0">
                        <!-- Orange accent bar -->
                        <Border
                            Grid.Column="0"
                            StrokeShape="RoundRectangle 16,0,0,16"
                            Stroke="Transparent">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="{StaticResource AppOrange}" Offset="0"/>
                                    <GradientStop Color="{StaticResource AppBlue}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Padding="18,20" Spacing="6">
                            <Label
                                Text="Featured Books"
                                FontFamily="OpenSansSemibold"
                                FontSize="15"
                                TextColor="{StaticResource AppTextPrimary}"/>
                            <Label
                                Text="Curated picks and new arrivals will appear here."
                                Style="{StaticResource MutedTextStyle}"
                                FontSize="13"
                                LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
