<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:AuthViewModel"
    Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
            <GradientStop Color="#7C2D12" Offset="0.0"/>
            <GradientStop Color="#C2410C" Offset="0.5"/>
            <GradientStop Color="#EA580C" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>

        <!-- Decorative orb — top right (amber glow) -->
        <Border
            HeightRequest="320" WidthRequest="320"
            StrokeShape="Ellipse"
            Stroke="Transparent" StrokeThickness="0"
            HorizontalOptions="End" VerticalOptions="Start"
            Margin="0,-100,-120,0"
            InputTransparent="True">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#60FBBF24" Offset="0.0"/>
                    <GradientStop Color="#00FBBF24" Offset="1.0"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Decorative orb — bottom left (orange glow) -->
        <Border
            HeightRequest="240" WidthRequest="240"
            StrokeShape="Ellipse"
            Stroke="Transparent" StrokeThickness="0"
            HorizontalOptions="Start" VerticalOptions="End"
            Margin="-80,0,0,-80"
            InputTransparent="True">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#40F97316" Offset="0.0"/>
                    <GradientStop Color="#00F97316" Offset="1.0"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Decorative orb — top left (warm accent) -->
        <Border
            HeightRequest="140" WidthRequest="140"
            StrokeShape="Ellipse"
            Stroke="Transparent" StrokeThickness="0"
            HorizontalOptions="Start" VerticalOptions="Start"
            Margin="-50,120,0,0"
            InputTransparent="True">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#40FBBF24" Offset="0.0"/>
                    <GradientStop Color="#00FBBF24" Offset="1.0"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Scrollable content -->
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- ── Hero section (on gradient) ─────────────────── -->
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    Spacing="10"
                    Padding="48,76,48,40">

                    <Image
                        Source="app_logo.png"
                        HeightRequest="68"
                        WidthRequest="68"
                        Aspect="AspectFit"
                        HorizontalOptions="Center"
                        Margin="0,0,0,6"/>

                    <Label
                        Text="{Binding FormTitle}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="28"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        Text="{Binding FormSubtitle}"
                        TextColor="White"
                        Opacity="0.75"
                        FontFamily="OpenSansRegular"
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>

                </VerticalStackLayout>

                <!-- ── Glass form card ────────────────────────────── -->
                <Border
                    x:Name="FormCard"
                    StrokeShape="RoundRectangle 32,32,0,0"
                    Stroke="#28FFFFFF"
                    StrokeThickness="1.5"
                    Padding="28,36,28,64"
                    MinimumHeightRequest="620">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFF9F5" Offset="0.0"/>
                            <GradientStop Color="#FFFBF8" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource AppNavyBrush}" Offset="0,-6" Radius="32" Opacity="0.18"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">

                        <!-- ── Verify Email ──────────────────────────── -->
                        <VerticalStackLayout
                            IsVisible="{Binding IsVerifyEmailMode}"
                            Spacing="16"
                            HorizontalOptions="Center"
                            Margin="0,0,0,28">

                            <Border
                                BackgroundColor="#FFF4ED"
                                StrokeShape="Ellipse"
                                Stroke="#FDDDB8"
                                StrokeThickness="1.5"
                                HeightRequest="92"
                                WidthRequest="92"
                                HorizontalOptions="Center">
                                <Label
                                    Text="@"
                                    FontSize="38"
                                    FontFamily="OpenSansSemibold"
                                    TextColor="{StaticResource AppNavy}"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Border>

                            <Label
                                Text="A verification link was sent to:"
                                TextColor="{StaticResource AppTextSecondary}"
                                FontSize="14"
                                HorizontalTextAlignment="Center"/>

                            <Border
                                BackgroundColor="#FFF4ED"
                                StrokeShape="RoundRectangle 10"
                                Stroke="#FDDDB8"
                                StrokeThickness="1"
                                Padding="20,10"
                                HorizontalOptions="Center">
                                <Label
                                    Text="{Binding Email}"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="14"
                                    TextColor="{StaticResource AppNavy}"
                                    HorizontalTextAlignment="Center"/>
                            </Border>

                            <Label
                                Text="Click the link in your inbox, then tap the button below."
                                TextColor="{StaticResource AppTextMuted}"
                                FontSize="13"
                                HorizontalTextAlignment="Center"
                                LineBreakMode="WordWrap"/>

                        </VerticalStackLayout>

                        <!-- ── Profile Setup ─────────────────────────── -->
                        <VerticalStackLayout
                            IsVisible="{Binding IsProfileSetupMode}"
                            Spacing="0"
                            Margin="0,0,0,20">

                            <!-- Required notice -->
                            <Border
                                BackgroundColor="#FFF4ED"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#FDDDB8"
                                StrokeThickness="1"
                                Padding="16,13"
                                Margin="0,0,0,26">
                                <Label
                                    Text="Please complete your profile to continue — this step is required."
                                    TextColor="{StaticResource AppNavy}"
                                    FontSize="13"
                                    LineBreakMode="WordWrap"
                                    HorizontalTextAlignment="Center"/>
                            </Border>

                            <!-- First Name -->
                            <Label
                                Text="FIRST NAME"
                                TextColor="{StaticResource AppTextSecondary}"
                                FontFamily="OpenSansSemibold"
                                FontSize="11"
                                CharacterSpacing="1.2"
                                Margin="2,0,0,8"/>
                            <Border Style="{StaticResource GlassEntryBorderStyle}">
                                <Entry
                                    Placeholder="Enter your first name"
                                    Text="{Binding FirstName}"
                                    ReturnType="Next"/>
                            </Border>

                            <!-- Last Name -->
                            <Label
                                Text="LAST NAME"
                                TextColor="{StaticResource AppTextSecondary}"
                                FontFamily="OpenSansSemibold"
                                FontSize="11"
                                CharacterSpacing="1.2"
                                Margin="2,22,0,8"/>
                            <Border Style="{StaticResource GlassEntryBorderStyle}">
                                <Entry
                                    Placeholder="Enter your last name"
                                    Text="{Binding LastName}"
                                    ReturnType="Next"/>
                            </Border>

                            <!-- Phone Number -->
                            <Label
                                Text="PHONE NUMBER"
                                TextColor="{StaticResource AppTextSecondary}"
                                FontFamily="OpenSansSemibold"
                                FontSize="11"
                                CharacterSpacing="1.2"
                                Margin="2,22,0,8"/>
                            <Border Style="{StaticResource GlassEntryBorderStyle}">
                                <Entry
                                    Placeholder="+1 234 567 8900"
                                    Text="{Binding PhoneNumber}"
                                    Keyboard="Telephone"
                                    ReturnType="Done"/>
                            </Border>

                        </VerticalStackLayout>

                        <!-- ── Email / Password ──────────────────────── -->
                        <VerticalStackLayout
                            IsVisible="{Binding ShowEmailPasswordFields}"
                            Spacing="0"
                            Margin="0,0,0,4">

                            <!-- Email -->
                            <Label
                                Text="EMAIL ADDRESS"
                                TextColor="{StaticResource AppTextSecondary}"
                                FontFamily="OpenSansSemibold"
                                FontSize="11"
                                CharacterSpacing="1.2"
                                Margin="2,0,0,8"/>
                            <Border
                                Style="{StaticResource GlassEntryBorderStyle}"
                                Stroke="{Binding HasEmailError, Converter={StaticResource ErrorBorderBrushConverter}}">
                                <Entry
                                    Placeholder="you@example.com"
                                    Text="{Binding Email}"
                                    Keyboard="Email"
                                    ReturnType="Next"/>
                            </Border>
                            <Label
                                Text="{Binding EmailError}"
                                Style="{StaticResource ErrorTextStyle}"
                                HorizontalTextAlignment="Start"
                                IsVisible="{Binding HasEmailError}"
                                Margin="2,7,0,0"/>

                            <!-- Password -->
                            <Label
                                Text="PASSWORD"
                                TextColor="{StaticResource AppTextSecondary}"
                                FontFamily="OpenSansSemibold"
                                FontSize="11"
                                CharacterSpacing="1.2"
                                Margin="2,22,0,8"/>
                            <Border
                                Style="{StaticResource GlassEntryBorderStyle}"
                                Stroke="{Binding HasPasswordError, Converter={StaticResource ErrorBorderBrushConverter}}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry
                                        Grid.Column="0"
                                        Placeholder="Enter password"
                                        Text="{Binding Password}"
                                        IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                                        ReturnType="Done"/>
                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding IsPasswordVisible, Converter={StaticResource BoolToEyeIconConverter}}"
                                        TextColor="{StaticResource AppOrange}"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="12"
                                        VerticalOptions="Center"
                                        Padding="12,0,2,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                            <Label
                                Text="{Binding PasswordError}"
                                Style="{StaticResource ErrorTextStyle}"
                                HorizontalTextAlignment="Start"
                                IsVisible="{Binding HasPasswordError}"
                                Margin="2,7,0,0"/>

                            <!-- Password strength bar -->
                            <Grid
                                ColumnDefinitions="*,6,*,6,*"
                                HeightRequest="4"
                                Margin="0,14,0,0"
                                IsVisible="{Binding ShowPasswordStrength}">
                                <BoxView Grid.Column="0" CornerRadius="2" BackgroundColor="{Binding StrengthSeg1Color}"/>
                                <BoxView Grid.Column="2" CornerRadius="2" BackgroundColor="{Binding StrengthSeg2Color}"/>
                                <BoxView Grid.Column="4" CornerRadius="2" BackgroundColor="{Binding StrengthSeg3Color}"/>
                            </Grid>
                            <Label
                                Text="{Binding PasswordStrengthText}"
                                FontSize="12"
                                TextColor="{Binding PasswordStrengthColor}"
                                IsVisible="{Binding ShowPasswordStrength}"
                                Margin="2,6,0,0"/>

                        </VerticalStackLayout>

                        <!-- Error banner -->
                        <Border
                            BackgroundColor="#FEF2F2"
                            StrokeShape="RoundRectangle 12"
                            Stroke="#FCA5A5"
                            StrokeThickness="1"
                            Padding="16,13"
                            Margin="0,20,0,0"
                            IsVisible="{Binding HasError}">
                            <Label
                                Text="{Binding ErrorMessage}"
                                TextColor="{StaticResource AppError}"
                                FontSize="13"
                                LineBreakMode="WordWrap"
                                HorizontalTextAlignment="Center"/>
                        </Border>

                        <!-- Status banner -->
                        <Border
                            BackgroundColor="#F0FDF4"
                            StrokeShape="RoundRectangle 12"
                            Stroke="#86EFAC"
                            StrokeThickness="1"
                            Padding="16,13"
                            Margin="0,10,0,0"
                            IsVisible="{Binding HasStatus}">
                            <Label
                                Text="{Binding StatusMessage}"
                                TextColor="{StaticResource AppSuccess}"
                                FontSize="13"
                                HorizontalTextAlignment="Center"/>
                        </Border>

                        <!-- Submit button (orange gradient) -->
                        <Button
                            Text="{Binding SubmitButtonText}"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            CornerRadius="16"
                            Padding="16,16"
                            MinimumHeightRequest="58"
                            HorizontalOptions="Fill"
                            Command="{Binding SubmitCommand}"
                            Margin="0,30,0,0">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F97316" Offset="0.0"/>
                                    <GradientStop Color="#C2410C" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Shadow>
                                <Shadow Brush="#80F97316" Offset="0,6" Radius="20" Opacity="0.5"/>
                            </Button.Shadow>
                        </Button>

                        <!-- Resend verification -->
                        <Label
                            IsVisible="{Binding IsVerifyEmailMode}"
                            HorizontalOptions="Center"
                            Margin="0,14,0,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Didn't receive it?  "
                                          TextColor="{StaticResource AppTextMuted}"
                                          FontSize="14"/>
                                    <Span Text="Resend"
                                          TextColor="{StaticResource AppOrange}"
                                          FontFamily="OpenSansSemibold"
                                          FontSize="14"/>
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ResendVerificationCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                        <!-- Loading indicator -->
                        <ActivityIndicator
                            IsRunning="{Binding IsBusy}"
                            IsVisible="{Binding IsBusy}"
                            Color="{StaticResource AppOrange}"
                            HorizontalOptions="Center"
                            Margin="0,18,0,0"/>

                        <!-- Toggle sign in / register -->
                        <HorizontalStackLayout
                            IsVisible="{Binding ShowToggleLink}"
                            HorizontalOptions="Center"
                            Spacing="5"
                            Margin="0,22,0,0">
                            <Label
                                Text="{Binding TogglePromptText}"
                                TextColor="{StaticResource AppTextMuted}"
                                FontSize="14"
                                VerticalOptions="Center"/>
                            <Label
                                Text="{Binding ToggleLinkText}"
                                TextColor="{StaticResource AppNavy}"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ToggleModeCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Close button -->
        <Button
            Text="✕"
            CornerRadius="20"
            HeightRequest="40" WidthRequest="40"
            Padding="0"
            FontSize="14"
            FontFamily="OpenSansSemibold"
            BackgroundColor="#25FFFFFF"
            TextColor="White"
            BorderWidth="0"
            HorizontalOptions="End"
            VerticalOptions="Start"
            Margin="0,54,20,0"
            IsVisible="{Binding IsProfileSetupMode, Converter={StaticResource InverseBoolConverter}}"
            Clicked="OnCloseClicked"/>

    </Grid>
</ContentPage>
