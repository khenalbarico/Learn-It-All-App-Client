<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.AuthPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:AuthViewModel"
    BackgroundColor="{StaticResource AppBackground}"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid RowDefinitions="Auto,*" Padding="0">

            <!-- Navy top bar with close button -->
            <Grid
                Grid.Row="0"
                BackgroundColor="{StaticResource AppNavy}"
                Padding="16,48,16,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label
                        Text="{Binding FormTitle}"
                        Style="{StaticResource OnDarkTitleStyle}"
                        FontSize="22"
                        HorizontalTextAlignment="Start"/>
                    <Label
                        Text="{Binding FormSubtitle}"
                        Style="{StaticResource OnDarkLabelStyle}"
                        FontSize="14"
                        Opacity="0.75"/>
                </VerticalStackLayout>

                <Button
                    Grid.Column="1"
                    Text="✕"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="18"
                    BorderWidth="0"
                    Padding="8"
                    MinimumHeightRequest="44"
                    MinimumWidthRequest="44"
                    VerticalOptions="Start"
                    Clicked="OnCloseClicked"/>
            </Grid>

            <!-- Form content -->
            <VerticalStackLayout
                Grid.Row="1"
                Padding="24,28,24,40"
                Spacing="0">

                <!-- Logo -->
                <Image
                    Source="app_logo.png"
                    HeightRequest="70"
                    WidthRequest="70"
                    Aspect="AspectFit"
                    HorizontalOptions="Center"
                    Margin="0,0,0,28"/>

                <!-- Verify email section -->
                <VerticalStackLayout IsVisible="{Binding IsVerifyEmailMode}" Spacing="12" Margin="0,0,0,24">

                    <Label
                        Text="✉"
                        FontSize="56"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource AppNavy}"
                        Margin="0,0,0,8"/>

                    <Label
                        Text="We sent a verification link to:"
                        FontSize="14"
                        TextColor="{StaticResource AppTextSecondary}"
                        HorizontalTextAlignment="Center"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="{Binding Email}"
                        FontSize="15"
                        FontAttributes="Bold"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"
                        HorizontalOptions="Center"/>

                    <Label
                        Text="Open the link in your inbox, then tap the button below to continue."
                        FontSize="13"
                        TextColor="{StaticResource AppTextSecondary}"
                        HorizontalTextAlignment="Center"
                        HorizontalOptions="Center"
                        Opacity="0.8"
                        Margin="0,4,0,0"/>

                </VerticalStackLayout>

                <!-- Profile setup fields -->
                <VerticalStackLayout IsVisible="{Binding IsProfileSetupMode}" Spacing="14" Margin="0,0,0,14">

                    <Label Text="First Name" Style="{StaticResource SectionTitleStyle}" FontSize="14" Margin="0,0,0,4"/>
                    <Border Style="{StaticResource EntryBorderStyle}">
                        <Entry Placeholder="Enter your first name" Text="{Binding FirstName}"/>
                    </Border>

                    <Label Text="Last Name" Style="{StaticResource SectionTitleStyle}" FontSize="14" Margin="0,0,0,4"/>
                    <Border Style="{StaticResource EntryBorderStyle}">
                        <Entry Placeholder="Enter your last name" Text="{Binding LastName}"/>
                    </Border>

                    <Label Text="Phone Number" Style="{StaticResource SectionTitleStyle}" FontSize="14" Margin="0,0,0,4"/>
                    <Border Style="{StaticResource EntryBorderStyle}">
                        <Entry
                            Placeholder="+1 234 567 8900"
                            Text="{Binding PhoneNumber}"
                            Keyboard="Telephone"/>
                    </Border>

                </VerticalStackLayout>

                <!-- Email / Password fields -->
                <VerticalStackLayout IsVisible="{Binding ShowEmailPasswordFields}" Spacing="0" Margin="0,0,0,14">

                    <!-- Email field -->
                    <Label
                        Text="Email Address"
                        Style="{StaticResource SectionTitleStyle}"
                        FontSize="14"
                        Margin="0,0,0,6"/>
                    <Border
                        Style="{StaticResource EntryBorderStyle}"
                        Stroke="{Binding HasEmailError, Converter={StaticResource ErrorBorderBrushConverter}}">
                        <Entry
                            Placeholder="you@example.com"
                            Text="{Binding Email}"
                            Keyboard="Email"/>
                    </Border>
                    <Label
                        Text="{Binding EmailError}"
                        Style="{StaticResource ErrorTextStyle}"
                        HorizontalTextAlignment="Start"
                        IsVisible="{Binding HasEmailError}"
                        Margin="4,4,0,0"/>

                    <!-- Password field -->
                    <Label
                        Text="Password"
                        Style="{StaticResource SectionTitleStyle}"
                        FontSize="14"
                        Margin="0,14,0,6"/>
                    <Border
                        Style="{StaticResource EntryBorderStyle}"
                        Stroke="{Binding HasPasswordError, Converter={StaticResource ErrorBorderBrushConverter}}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry
                                Grid.Column="0"
                                Placeholder="Enter password"
                                Text="{Binding Password}"
                                IsPassword="{Binding IsPasswordVisible, Converter={x:StaticResource InverseBoolConverter}}"/>
                            <Button
                                Grid.Column="1"
                                Text="{Binding IsPasswordVisible, Converter={x:StaticResource BoolToEyeIconConverter}}"
                                Style="{StaticResource GhostButtonStyle}"
                                TextColor="{StaticResource AppTextSecondary}"
                                FontSize="16"
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                    <Label
                        Text="{Binding PasswordError}"
                        Style="{StaticResource ErrorTextStyle}"
                        HorizontalTextAlignment="Start"
                        IsVisible="{Binding HasPasswordError}"
                        Margin="4,4,0,0"/>

                    <!-- Password strength indicator (Register mode only) -->
                    <Label
                        Text="{Binding PasswordStrengthText}"
                        FontSize="12"
                        FontFamily="OpenSansRegular"
                        TextColor="{Binding PasswordStrengthColor}"
                        IsVisible="{Binding ShowPasswordStrength}"
                        Margin="4,6,0,0"/>

                </VerticalStackLayout>

                <!-- Error message -->
                <Label
                    Text="{Binding ErrorMessage}"
                    Style="{StaticResource ErrorTextStyle}"
                    IsVisible="{Binding HasError}"
                    Margin="0,0,0,12"/>

                <!-- Status message (e.g. email resent confirmation) -->
                <Label
                    Text="{Binding StatusMessage}"
                    FontSize="13"
                    TextColor="#2E7D32"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding HasStatus}"
                    Margin="0,0,0,12"/>

                <!-- Submit button -->
                <Button
                    Text="{Binding SubmitButtonText}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SubmitCommand}"
                    IsEnabled="{Binding IsBusy, Converter={x:StaticResource InverseBoolConverter}}"
                    Margin="0,8,0,0"/>

                <!-- Resend verification email button -->
                <Button
                    Text="Resend Email"
                    Style="{StaticResource GhostButtonStyle}"
                    IsVisible="{Binding IsVerifyEmailMode}"
                    Command="{Binding ResendVerificationCommand}"
                    IsEnabled="{Binding IsBusy, Converter={x:StaticResource InverseBoolConverter}}"
                    HorizontalOptions="Center"
                    Margin="0,8,0,0"/>

                <!-- Loading indicator -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    HorizontalOptions="Center"
                    Margin="0,16,0,0"/>

                <!-- Toggle sign in / register -->
                <Button
                    Text="{Binding ToggleModeText}"
                    Style="{StaticResource GhostButtonStyle}"
                    IsVisible="{Binding ShowToggleLink}"
                    Command="{Binding ToggleModeCommand}"
                    HorizontalOptions="Center"
                    Margin="0,20,0,0"/>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>

</ContentPage>
