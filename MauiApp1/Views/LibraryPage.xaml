<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    xmlns:models="clr-namespace:LogicLib1.Models.App;assembly=LogicLib1"
    x:DataType="vm:LibraryViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Custom header with integrated search -->
        <Grid
            Grid.Row="0"
            BackgroundColor="{StaticResource AppNavy}"
            Padding="20,52,20,16">
            <VerticalStackLayout Spacing="14">
                <Label
                    Text="Browse Books"
                    TextColor="White"
                    FontFamily="OpenSansSemibold"
                    FontSize="26"/>
                <Border
                    BackgroundColor="#26FFFFFF"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Padding="4,0">
                    <SearchBar
                        Text="{Binding SearchText}"
                        Placeholder="Search by title or category..."
                        PlaceholderColor="#80FFFFFF"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        CancelButtonColor="White"/>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- Guest banner -->
        <Border
            Grid.Row="1"
            BackgroundColor="{StaticResource AppOrange}"
            StrokeShape="Rectangle"
            Stroke="Transparent"
            Padding="20,12"
            IsVisible="{Binding IsGuest}">
            <Label
                Text="Sign in to purchase and read full books"
                TextColor="White"
                FontFamily="OpenSansSemibold"
                FontSize="13"
                HorizontalTextAlignment="Center"/>
        </Border>

        <!-- Books grid -->
        <RefreshView
            Grid.Row="2"
            Command="{Binding RefreshCommand}"
            IsRefreshing="{Binding IsRefreshing}">

            <CollectionView
                ItemsSource="{Binding FilteredBooks}"
                Margin="14,14,14,0">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout
                        Orientation="Vertical"
                        Span="2"
                        HorizontalItemSpacing="10"
                        VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Spacing="12"
                        Padding="40"
                        Margin="0,60,0,0">
                        <Label
                            Text="📚"
                            FontSize="48"
                            HorizontalOptions="Center"/>
                        <Label
                            Text="No books found"
                            FontFamily="OpenSansSemibold"
                            FontSize="16"
                            TextColor="{StaticResource AppTextPrimary}"
                            HorizontalTextAlignment="Center"/>
                        <Label
                            Text="Try a different search term."
                            Style="{StaticResource MutedTextStyle}"
                            FontSize="13"
                            HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BookMetadata">
                        <Border Style="{StaticResource CardStyle}" Margin="0">
                            <Grid RowDefinitions="160,Auto">

                                <!-- Cover image -->
                                <Border
                                    Grid.Row="0"
                                    BackgroundColor="{StaticResource AppSurfaceVariant}"
                                    StrokeShape="RoundRectangle 12,12,0,0"
                                    Stroke="Transparent"
                                    StrokeThickness="0">
                                    <Grid>
                                        <Image
                                            Source="{Binding ImageCoverUrl}"
                                            Aspect="AspectFill"
                                            IsVisible="{Binding ImageCoverUrl, Converter={x:StaticResource NotNullConverter}}"/>
                                        <VerticalStackLayout
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center"
                                            IsVisible="{Binding ImageCoverUrl, Converter={x:StaticResource NullConverter}}">
                                            <Label
                                                Text="📚"
                                                FontSize="36"
                                                HorizontalOptions="Center"
                                                Opacity="0.4"/>
                                        </VerticalStackLayout>
                                        <!-- Category badge -->
                                        <Border
                                            BackgroundColor="#CC1B3A6B"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="Transparent"
                                            Padding="8,4"
                                            HorizontalOptions="Start"
                                            VerticalOptions="End"
                                            Margin="8,0,0,8">
                                            <Label
                                                Text="{Binding Category}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="10"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Book details -->
                                <VerticalStackLayout
                                    Grid.Row="1"
                                    Padding="12,10,12,12"
                                    Spacing="4">

                                    <Label
                                        Text="{Binding Title}"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="13"
                                        TextColor="{StaticResource AppTextPrimary}"
                                        MaxLines="2"
                                        LineBreakMode="TailTruncation"/>

                                    <Label
                                        Text="{Binding Price, StringFormat='${0:F2}'}"
                                        TextColor="{StaticResource AppNavy}"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="15"
                                        Margin="0,2,0,6"/>

                                    <Button
                                        Text="Buy Now"
                                        Style="{StaticResource SmallPrimaryButtonStyle}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BuyCommand}"
                                        CommandParameter="{Binding .}"/>

                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

        <!-- Loading overlay -->
        <Grid
            Grid.Row="2"
            IsVisible="{Binding IsBusy}"
            BackgroundColor="{StaticResource AppBackground}">
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                VerticalOptions="Center"
                HorizontalOptions="Center"/>
        </Grid>

        <!-- Error snackbar -->
        <Border
            Grid.Row="2"
            IsVisible="{Binding HasError}"
            BackgroundColor="{StaticResource AppNavy}"
            StrokeShape="RoundRectangle 12"
            Stroke="Transparent"
            Padding="16,12"
            Margin="16,0,16,24"
            VerticalOptions="End">
            <Label
                Text="{Binding ErrorMessage}"
                TextColor="White"
                FontSize="13"
                HorizontalTextAlignment="Center"/>
        </Border>

    </Grid>
</ContentPage>
