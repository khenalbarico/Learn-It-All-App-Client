<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    xmlns:models="clr-namespace:LogicLib1.Models.App;assembly=LogicLib1"
    x:DataType="vm:LibraryViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Gradient header with category selectors ───────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                    <GradientStop Color="#7C2D12" Offset="0.0"/>
                    <GradientStop Color="#C2410C" Offset="0.5"/>
                    <GradientStop Color="#EA580C" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Decorative orb — top right (amber) -->
            <Border
                HeightRequest="240" WidthRequest="240"
                StrokeShape="Ellipse"
                Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,-80,-100,0"
                InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#50FBBF24" Offset="0.0"/>
                        <GradientStop Color="#00FBBF24" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- Header content -->
            <VerticalStackLayout Padding="20,52,20,24" Spacing="0">

                <Label
                    Text="Browse Books"
                    TextColor="White"
                    FontFamily="OpenSansSemibold"
                    FontSize="28"
                    HorizontalTextAlignment="Start"/>

                <Label
                    Text="Select a category to explore"
                    TextColor="White"
                    Opacity="0.7"
                    FontFamily="OpenSansRegular"
                    FontSize="13"
                    Margin="0,4,0,0"/>

                <!-- Category selector buttons -->
                <Grid ColumnDefinitions="*,12,*" Margin="0,20,0,0">

                    <!-- College Course -->
                    <Border
                        Grid.Column="0"
                        StrokeShape="RoundRectangle 16"
                        Stroke="#40FFFFFF"
                        StrokeThickness="1.5"
                        BackgroundColor="#18FFFFFF"
                        Padding="12,14">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCollegeCourseSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource AppOrange}"/>
                                <Setter Property="Stroke" Value="Transparent"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="0">
                            <HorizontalStackLayout
                                Grid.Column="0"
                                Spacing="2"
                                VerticalOptions="Center"
                                Margin="0,0,10,0">
                                <BoxView WidthRequest="4" HeightRequest="20" CornerRadius="2" BackgroundColor="White" Opacity="0.7"/>
                                <BoxView WidthRequest="4" HeightRequest="26" CornerRadius="2" BackgroundColor="White" Opacity="0.9"/>
                                <BoxView WidthRequest="4" HeightRequest="18" CornerRadius="2" BackgroundColor="White" Opacity="0.6"/>
                            </HorizontalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Start" Spacing="2">
                                <Label
                                    Text="College"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"/>
                                <Label
                                    Text="Undergraduate"
                                    TextColor="White"
                                    Opacity="0.65"
                                    FontFamily="OpenSansRegular"
                                    FontSize="10"/>
                            </VerticalStackLayout>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="CollegeCourse"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Board Exam Reviewer -->
                    <Border
                        Grid.Column="2"
                        StrokeShape="RoundRectangle 16"
                        Stroke="#40FFFFFF"
                        StrokeThickness="1.5"
                        BackgroundColor="#18FFFFFF"
                        Padding="12,14">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsReviewerSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource AppOrange}"/>
                                <Setter Property="Stroke" Value="Transparent"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="0">
                            <VerticalStackLayout
                                Grid.Column="0"
                                Spacing="4"
                                VerticalOptions="Center"
                                Margin="0,0,10,0">
                                <BoxView WidthRequest="20" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.9"/>
                                <BoxView WidthRequest="14" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.65"/>
                                <BoxView WidthRequest="17" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.75"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Start" Spacing="2">
                                <Label
                                    Text="Board Exam"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"/>
                                <Label
                                    Text="Reviewer"
                                    TextColor="White"
                                    Opacity="0.65"
                                    FontFamily="OpenSansRegular"
                                    FontSize="10"/>
                            </VerticalStackLayout>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCategoryCommand}" CommandParameter="Reviewer"/>
                        </Border.GestureRecognizers>
                    </Border>

                </Grid>

                <!-- Search bar -->
                <Border
                    IsVisible="{Binding HasSelectedCategory}"
                    BackgroundColor="#20FFFFFF"
                    StrokeShape="RoundRectangle 12"
                    Stroke="#28FFFFFF"
                    StrokeThickness="1"
                    Padding="4,0"
                    Margin="0,16,0,0">
                    <SearchBar
                        Text="{Binding SearchText}"
                        Placeholder="Search books..."
                        PlaceholderColor="#70FFFFFF"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        CancelButtonColor="White"/>
                </Border>

            </VerticalStackLayout>
        </Grid>

        <!-- ── Guest banner ──────────────────────────────────────── -->
        <Border
            Grid.Row="1"
            StrokeShape="Rectangle"
            Stroke="Transparent"
            StrokeThickness="0"
            Padding="20,12"
            IsVisible="{Binding IsGuest}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#C2410C" Offset="0.0"/>
                    <GradientStop Color="#F97316" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto">
                <Label
                    Grid.Column="0"
                    Text="Sign in to purchase and read full books"
                    TextColor="White"
                    FontFamily="OpenSansSemibold"
                    FontSize="13"
                    VerticalOptions="Center"/>
                <Label
                    Grid.Column="1"
                    Text="›"
                    TextColor="White"
                    FontSize="20"
                    VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- ── Content area ───────────────────────────────────────── -->
        <Grid Grid.Row="2">

            <!-- No category selected — invite state -->
            <VerticalStackLayout
                IsVisible="{Binding HasSelectedCategory, Converter={StaticResource InverseBoolConverter}}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="18"
                Padding="44,0">

                <!-- Colorful book spines -->
                <StackLayout
                    Orientation="Horizontal"
                    HorizontalOptions="Center"
                    Spacing="6"
                    Margin="0,0,0,4">
                    <Border
                        StrokeShape="RoundRectangle 4"
                        Stroke="Transparent"
                        WidthRequest="12"
                        HeightRequest="52">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F97316" Offset="0"/>
                                <GradientStop Color="#C2410C" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border
                        StrokeShape="RoundRectangle 4"
                        Stroke="Transparent"
                        WidthRequest="12"
                        HeightRequest="64">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1E40AF" Offset="0"/>
                                <GradientStop Color="#1D4ED8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border
                        StrokeShape="RoundRectangle 4"
                        Stroke="Transparent"
                        WidthRequest="12"
                        HeightRequest="52">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#EA580C" Offset="0"/>
                                <GradientStop Color="#9A3412" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border
                        StrokeShape="RoundRectangle 4"
                        Stroke="Transparent"
                        WidthRequest="12"
                        HeightRequest="58">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FBBF24" Offset="0"/>
                                <GradientStop Color="#F59E0B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackLayout>

                <Label
                    Text="Choose a Category"
                    FontFamily="OpenSansSemibold"
                    FontSize="22"
                    TextColor="{StaticResource AppNavy}"
                    HorizontalTextAlignment="Center"/>

                <Label
                    Text="Tap College Course or Board Exam Reviewer above to browse available books."
                    Style="{StaticResource MutedTextStyle}"
                    FontSize="14"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"/>

            </VerticalStackLayout>

            <!-- Books grid -->
            <RefreshView
                IsVisible="{Binding HasSelectedCategory}"
                Command="{Binding RefreshCommand}"
                IsRefreshing="{Binding IsRefreshing}">

                <CollectionView
                    ItemsSource="{Binding FilteredBooks}"
                    Margin="14,14,14,0">

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="2"
                            HorizontalItemSpacing="10"
                            VerticalItemSpacing="12"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            Spacing="12"
                            Padding="40"
                            Margin="0,60,0,0">

                            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="5">
                                <BoxView WidthRequest="8" HeightRequest="32" CornerRadius="3" BackgroundColor="{StaticResource AppTextMuted}"/>
                                <BoxView WidthRequest="8" HeightRequest="32" CornerRadius="3" BackgroundColor="{StaticResource AppTextMuted}" Opacity="0.5"/>
                                <BoxView WidthRequest="8" HeightRequest="32" CornerRadius="3" BackgroundColor="{StaticResource AppTextMuted}" Opacity="0.3"/>
                            </StackLayout>

                            <Label
                                Text="No books found"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                TextColor="{StaticResource AppTextPrimary}"
                                HorizontalTextAlignment="Center"/>
                            <Label
                                Text="Try a different search term."
                                Style="{StaticResource MutedTextStyle}"
                                FontSize="13"
                                HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BookMetadata">
                            <Border Style="{StaticResource CardStyle}" Margin="0">
                                <Grid RowDefinitions="165,Auto">

                                    <!-- Cover image area — clipped Border prevents AspectFill overflow -->
                                    <Border
                                        Grid.Row="0"
                                        StrokeShape="RoundRectangle 16,16,0,0"
                                        Stroke="Transparent"
                                        StrokeThickness="0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C2D12" Offset="0.0"/>
                                                <GradientStop Color="#C2410C" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <Grid>
                                            <!-- Decorative page lines shown when no cover image -->
                                            <VerticalStackLayout
                                                Spacing="6"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding ImageCoverUrl, Converter={x:StaticResource NullConverter}}">
                                                <BoxView WidthRequest="48" HeightRequest="3" CornerRadius="1.5" BackgroundColor="White" Opacity="0.2"/>
                                                <BoxView WidthRequest="36" HeightRequest="3" CornerRadius="1.5" BackgroundColor="White" Opacity="0.15"/>
                                                <BoxView WidthRequest="44" HeightRequest="3" CornerRadius="1.5" BackgroundColor="White" Opacity="0.2"/>
                                                <BoxView WidthRequest="28" HeightRequest="3" CornerRadius="1.5" BackgroundColor="White" Opacity="0.1"/>
                                            </VerticalStackLayout>

                                            <!-- Cover image — clips to parent Border's RoundRectangle -->
                                            <Image
                                                Source="{Binding ImageCoverUrl, Converter={x:StaticResource ImageCoverConverter}}"
                                                Aspect="AspectFill"
                                                IsVisible="{Binding ImageCoverUrl, Converter={x:StaticResource NotNullConverter}}"/>

                                            <!-- Bottom scrim -->
                                            <Border
                                                StrokeShape="Rectangle"
                                                Stroke="Transparent"
                                                VerticalOptions="End"
                                                HeightRequest="48">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#007C2D12" Offset="0"/>
                                                        <GradientStop Color="#887C2D12" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <!-- Category badge -->
                                            <Border
                                                BackgroundColor="#CC1C1917"
                                                StrokeShape="RoundRectangle 7"
                                                Stroke="Transparent"
                                                Padding="8,4"
                                                HorizontalOptions="Start"
                                                VerticalOptions="End"
                                                Margin="10,0,0,10">
                                                <Label
                                                    Text="{Binding Category}"
                                                    TextColor="White"
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="9"
                                                    CharacterSpacing="0.5"/>
                                            </Border>

                                            <!-- Price badge -->
                                            <Border
                                                BackgroundColor="{StaticResource AppOrange}"
                                                StrokeShape="RoundRectangle 0,10,0,10"
                                                Stroke="Transparent"
                                                Padding="8,4"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                Margin="0,12,0,0">
                                                <Label
                                                    Text="{Binding Price, StringFormat='₱{0:F0}'}"
                                                    TextColor="White"
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="11"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Book details -->
                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Padding="12,10,12,13"
                                        Spacing="4">

                                        <Label
                                            Text="{Binding Title}"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="13"
                                            TextColor="{StaticResource AppTextPrimary}"
                                            MaxLines="2"
                                            LineBreakMode="TailTruncation"/>

                                        <Button
                                            Text="Buy Now"
                                            TextColor="White"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="12"
                                            CornerRadius="10"
                                            Padding="8,7"
                                            MinimumHeightRequest="38"
                                            HorizontalOptions="Fill"
                                            Margin="0,4,0,0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BuyCommand}"
                                            CommandParameter="{Binding .}">
                                            <Button.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#F97316" Offset="0.0"/>
                                                    <GradientStop Color="#C2410C" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Button.Background>
                                        </Button>

                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </RefreshView>

            <!-- Loading overlay -->
            <Grid
                IsVisible="{Binding IsBusy}"
                BackgroundColor="{StaticResource AppBackground}">
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    Color="{StaticResource AppOrange}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>
            </Grid>

            <!-- Error snackbar -->
            <Border
                IsVisible="{Binding HasError}"
                BackgroundColor="{StaticResource AppNavy}"
                StrokeShape="RoundRectangle 12"
                Stroke="Transparent"
                Padding="16,12"
                Margin="16,0,16,24"
                VerticalOptions="End">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="White"
                    FontSize="13"
                    HorizontalTextAlignment="Center"/>
            </Border>

        </Grid>

    </Grid>
</ContentPage>
