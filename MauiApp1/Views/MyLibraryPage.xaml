<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.MyLibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    xmlns:models="clr-namespace:LogicLib1.Models.App;assembly=LogicLib1"
    x:DataType="vm:MyLibraryViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Gradient header ────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                    <GradientStop Color="#0D1830" Offset="0.0"/>
                    <GradientStop Color="#1A3660" Offset="0.5"/>
                    <GradientStop Color="#2A5298" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Decorative orb — top right -->
            <Border
                HeightRequest="160" WidthRequest="160"
                StrokeShape="Ellipse"
                Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,-50,-60,0"
                InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#40F5A623" Offset="0.0"/>
                        <GradientStop Color="#00F5A623" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <VerticalStackLayout Padding="20,52,20,28" Spacing="4">
                <Label
                    Text="My Library"
                    TextColor="White"
                    FontFamily="OpenSansSemibold"
                    FontSize="26"/>
                <Label
                    Text="Books you've purchased"
                    TextColor="White"
                    Opacity="0.65"
                    FontFamily="OpenSansRegular"
                    FontSize="13"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Content area ───────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- Guest state -->
            <VerticalStackLayout
                IsVisible="{Binding IsGuest}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="16"
                Padding="36">

                <!-- Geometric book icon -->
                <Border
                    StrokeShape="RoundRectangle 20"
                    Stroke="#DDE4F0"
                    StrokeThickness="1.5"
                    HeightRequest="80"
                    WidthRequest="80"
                    HorizontalOptions="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#EEF2F8" Offset="0"/>
                            <GradientStop Color="#D8E4F4" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                        <Border StrokeShape="RoundRectangle 3" Stroke="Transparent" WidthRequest="16" HeightRequest="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#2E7BC4" Offset="0"/>
                                    <GradientStop Color="#1B3A6B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border StrokeShape="RoundRectangle 3" Stroke="Transparent" WidthRequest="16" HeightRequest="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#1A3660" Offset="0"/>
                                    <GradientStop Color="#0D1830" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackLayout>
                </Border>

                <Label
                    Text="Your Library Awaits"
                    FontFamily="OpenSansSemibold"
                    FontSize="22"
                    TextColor="{StaticResource AppNavy}"
                    HorizontalTextAlignment="Center"/>

                <Label
                    Text="Sign in to see the books you've purchased and start reading."
                    Style="{StaticResource BodyTextStyle}"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"/>

                <Button
                    Text="Sign In"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding NavigateToAuthCommand}"
                    Margin="0,8,0,0"/>

            </VerticalStackLayout>

            <!-- Authenticated state -->
            <Grid IsVisible="{Binding IsAuthenticated}">

                <!-- Loading spinner -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="{StaticResource AppOrange}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>

                <!-- Empty library state -->
                <VerticalStackLayout
                    IsVisible="{Binding ShowEmptyState}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="14"
                    Padding="40">

                    <!-- Empty box icon -->
                    <Border
                        StrokeShape="RoundRectangle 20"
                        Stroke="#DDE4F0"
                        StrokeThickness="1.5"
                        HeightRequest="80"
                        WidthRequest="80"
                        HorizontalOptions="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EEF2F8" Offset="0"/>
                                <GradientStop Color="#D8E4F4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <BoxView
                            WidthRequest="28"
                            HeightRequest="28"
                            CornerRadius="6"
                            BackgroundColor="{StaticResource AppTextMuted}"
                            Opacity="0.4"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Border>

                    <Label
                        Text="No books yet"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        Text="Books you purchase will appear here. Head to the Library to find something great."
                        Style="{StaticResource MutedTextStyle}"
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>

                </VerticalStackLayout>

                <!-- Books grid -->
                <CollectionView
                    ItemsSource="{Binding PurchasedBooks}"
                    IsVisible="{Binding HasBooks}"
                    Margin="14,14,14,0">

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="2"
                            HorizontalItemSpacing="10"
                            VerticalItemSpacing="12"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BookMetadata">
                            <Border Style="{StaticResource CardStyle}" Margin="0">
                                <Grid RowDefinitions="160,Auto">

                                    <!-- Cover / gradient placeholder -->
                                    <Grid Grid.Row="0">
                                        <Border StrokeShape="RoundRectangle 12,12,0,0" Stroke="Transparent" StrokeThickness="0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#1A3660" Offset="0.0"/>
                                                    <GradientStop Color="#2E7BC4" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Image
                                            Source="{Binding ImageCoverUrl}"
                                            Aspect="AspectFill"
                                            IsVisible="{Binding ImageCoverUrl, Converter={x:StaticResource NotNullConverter}}"/>
                                    </Grid>

                                    <VerticalStackLayout Grid.Row="1" Padding="12,10,12,12" Spacing="4">
                                        <Label
                                            Text="{Binding Title}"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="13"
                                            TextColor="{StaticResource AppTextPrimary}"
                                            MaxLines="2"
                                            LineBreakMode="TailTruncation"/>
                                        <Label
                                            Text="{Binding Category}"
                                            Style="{StaticResource MutedTextStyle}"
                                            FontSize="11"
                                            Margin="0,0,0,4"/>
                                        <Button
                                            Text="Read"
                                            TextColor="White"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="12"
                                            CornerRadius="8"
                                            Padding="8,6"
                                            MinimumHeightRequest="36"
                                            HorizontalOptions="Fill"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ReadCommand}"
                                            CommandParameter="{Binding .}">
                                            <Button.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#F5A623" Offset="0.0"/>
                                                    <GradientStop Color="#D4890F" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Button.Background>
                                        </Button>
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </Grid>

            <!-- Error snackbar -->
            <Border
                IsVisible="{Binding HasError}"
                BackgroundColor="{StaticResource AppError}"
                StrokeShape="RoundRectangle 12"
                Stroke="Transparent"
                Padding="16,12"
                Margin="16,0,16,24"
                VerticalOptions="End">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="White"
                    FontSize="13"
                    HorizontalTextAlignment="Center"/>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
