<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.MyLibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:MyLibraryViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                    <GradientStop Color="#0D1830" Offset="0.0"/>
                    <GradientStop Color="#1A3660" Offset="0.5"/>
                    <GradientStop Color="#2A5298" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border
                HeightRequest="160" WidthRequest="160"
                StrokeShape="Ellipse"
                Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,-50,-60,0"
                InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#40F5A623" Offset="0.0"/>
                        <GradientStop Color="#00F5A623" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <VerticalStackLayout Padding="20,52,20,28" Spacing="4">
                <Label
                    Text="My Library"
                    TextColor="White"
                    FontFamily="OpenSansSemibold"
                    FontSize="26"/>
                <Label
                    Text="Books you've purchased"
                    TextColor="White"
                    Opacity="0.65"
                    FontFamily="OpenSansRegular"
                    FontSize="13"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Content ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- Guest state -->
            <VerticalStackLayout
                IsVisible="{Binding IsGuest}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="16"
                Padding="36">

                <Border
                    StrokeShape="RoundRectangle 20"
                    Stroke="#DDE4F0"
                    StrokeThickness="1.5"
                    HeightRequest="80"
                    WidthRequest="80"
                    HorizontalOptions="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#EEF2F8" Offset="0"/>
                            <GradientStop Color="#D8E4F4" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout
                        Orientation="Horizontal"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="4">
                        <Border StrokeShape="RoundRectangle 3" Stroke="Transparent" WidthRequest="16" HeightRequest="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#2E7BC4" Offset="0"/>
                                    <GradientStop Color="#1B3A6B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border StrokeShape="RoundRectangle 3" Stroke="Transparent" WidthRequest="16" HeightRequest="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#1A3660" Offset="0"/>
                                    <GradientStop Color="#0D1830" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackLayout>
                </Border>

                <Label
                    Text="Your Library Awaits"
                    FontFamily="OpenSansSemibold"
                    FontSize="22"
                    TextColor="{StaticResource AppNavy}"
                    HorizontalTextAlignment="Center"/>

                <Label
                    Text="Sign in to see the books you've purchased and start reading."
                    Style="{StaticResource BodyTextStyle}"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"/>

                <Button
                    Text="Sign In"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding NavigateToAuthCommand}"
                    Margin="0,8,0,0"/>

            </VerticalStackLayout>

            <!-- Authenticated state -->
            <Grid IsVisible="{Binding IsAuthenticated}">

                <!-- Loading spinner -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="{StaticResource AppOrange}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>

                <!-- Empty library state -->
                <VerticalStackLayout
                    IsVisible="{Binding ShowEmptyState}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="14"
                    Padding="40">

                    <Border
                        StrokeShape="RoundRectangle 20"
                        Stroke="#DDE4F0"
                        StrokeThickness="1.5"
                        HeightRequest="80"
                        WidthRequest="80"
                        HorizontalOptions="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EEF2F8" Offset="0"/>
                                <GradientStop Color="#D8E4F4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <BoxView
                            WidthRequest="28" HeightRequest="28"
                            CornerRadius="6"
                            BackgroundColor="{StaticResource AppTextMuted}"
                            Opacity="0.4"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Border>

                    <Label
                        Text="No books yet"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        Text="Books you purchase will appear here. Head to the Library to find something great."
                        Style="{StaticResource MutedTextStyle}"
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>

                </VerticalStackLayout>

                <!-- ── Books accordion list ─────────────────────── -->
                <ScrollView IsVisible="{Binding HasBooks}">
                    <VerticalStackLayout
                        x:Name="LibraryGroupsLayout"
                        Padding="16,16,16,32"
                        Spacing="10"
                        BindableLayout.ItemsSource="{Binding LibraryGroups}">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:LibraryBookGroup">

                                <Border
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="{StaticResource AppDivider}"
                                    StrokeThickness="1"
                                    BackgroundColor="{StaticResource AppSurface}">

                                    <VerticalStackLayout Spacing="0">

                                        <!-- Book header row — tap to expand/collapse -->
                                        <Grid
                                            ColumnDefinitions="Auto,*,Auto"
                                            Padding="14,14">

                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding ToggleCommand}"/>
                                            </Grid.GestureRecognizers>

                                            <!-- Cover thumbnail -->
                                            <Border
                                                Grid.Column="0"
                                                StrokeShape="RoundRectangle 10"
                                                Stroke="Transparent"
                                                WidthRequest="54"
                                                HeightRequest="70"
                                                Margin="0,0,14,0">
                                                <Grid>
                                                    <Image
                                                        Source="my_library_book_ico.png"
                                                        Aspect="AspectFit"
                                                        Margin="6"/>
                                                    <Image
                                                        Source="{Binding Book.ImageCoverUrl}"
                                                        Aspect="AspectFill"
                                                        IsVisible="{Binding Book.ImageCoverUrl, Converter={x:StaticResource NotNullConverter}}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Title + doc count -->
                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                VerticalOptions="Center"
                                                Spacing="4">
                                                <Label
                                                    Text="{Binding Label}"
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="15"
                                                    TextColor="{StaticResource AppNavy}"
                                                    LineBreakMode="WordWrap"/>
                                                <Label
                                                    Text="{Binding DocCount, StringFormat='{0} document(s)'}"
                                                    FontFamily="OpenSansRegular"
                                                    FontSize="12"
                                                    TextColor="{StaticResource AppTextMuted}"/>
                                            </VerticalStackLayout>

                                            <!-- Arrow indicator -->
                                            <Label
                                                Grid.Column="2"
                                                Text="▶"
                                                FontSize="16"
                                                TextColor="{StaticResource AppTextMuted}"
                                                VerticalOptions="Center"
                                                Margin="10,0,0,0">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="Text" Value="▼"/>
                                                        <Setter Property="TextColor" Value="{StaticResource AppOrange}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>

                                        </Grid>

                                        <!-- Divider (shown only when expanded) -->
                                        <BoxView
                                            HeightRequest="1"
                                            BackgroundColor="{StaticResource AppDivider}"
                                            IsVisible="{Binding IsExpanded}"/>

                                        <!-- Documents list -->
                                        <VerticalStackLayout
                                            Spacing="0"
                                            IsVisible="{Binding IsExpanded}"
                                            BindableLayout.ItemsSource="{Binding DocItems}">

                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="vm:DocItem">

                                                    <Grid
                                                        ColumnDefinitions="Auto,*,Auto"
                                                        Padding="16,13"
                                                        BackgroundColor="Transparent">

                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding OpenCommand}"/>
                                                        </Grid.GestureRecognizers>

                                                        <!-- Doc icon dot -->
                                                        <BoxView
                                                            Grid.Column="0"
                                                            WidthRequest="7"
                                                            HeightRequest="7"
                                                            CornerRadius="4"
                                                            BackgroundColor="{StaticResource AppOrange}"
                                                            VerticalOptions="Center"
                                                            Margin="14,0,14,0"/>

                                                        <!-- Doc title -->
                                                        <Label
                                                            Grid.Column="1"
                                                            Text="{Binding DisplayTitle}"
                                                            FontFamily="OpenSansRegular"
                                                            FontSize="14"
                                                            TextColor="{StaticResource AppTextPrimary}"
                                                            VerticalOptions="Center"/>

                                                        <!-- Read arrow -->
                                                        <Label
                                                            Grid.Column="2"
                                                            Text="Read  →"
                                                            FontFamily="OpenSansSemibold"
                                                            FontSize="12"
                                                            TextColor="{StaticResource AppOrange}"
                                                            VerticalOptions="Center"
                                                            Margin="8,0,4,0"/>

                                                    </Grid>

                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>

                                        </VerticalStackLayout>

                                    </VerticalStackLayout>
                                </Border>

                            </DataTemplate>
                        </BindableLayout.ItemTemplate>

                    </VerticalStackLayout>
                </ScrollView>

            </Grid>

            <!-- Error snackbar -->
            <Border
                IsVisible="{Binding HasError}"
                BackgroundColor="{StaticResource AppError}"
                StrokeShape="RoundRectangle 12"
                Stroke="Transparent"
                Padding="16,12"
                Margin="16,0,16,24"
                VerticalOptions="End">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="White"
                    FontSize="13"
                    HorizontalTextAlignment="Center"/>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
