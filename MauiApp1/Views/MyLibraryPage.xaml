<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.MyLibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:MyLibraryViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ──────────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                    <GradientStop Color="#7C2D12" Offset="0.0"/>
                    <GradientStop Color="#C2410C" Offset="0.5"/>
                    <GradientStop Color="#EA580C" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Amber orb — top right -->
            <Border
                HeightRequest="160" WidthRequest="160"
                StrokeShape="Ellipse"
                Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,-50,-60,0"
                InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#40FBBF24" Offset="0.0"/>
                        <GradientStop Color="#00FBBF24" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <VerticalStackLayout Padding="20,52,20,28" Spacing="4">
                <Label
                    Text="My Library"
                    TextColor="White"
                    FontFamily="OpenSansSemibold"
                    FontSize="28"/>
                <Label
                    Text="Books you've purchased"
                    TextColor="White"
                    Opacity="0.7"
                    FontFamily="OpenSansRegular"
                    FontSize="13"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Content ─────────────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- Guest state -->
            <VerticalStackLayout
                IsVisible="{Binding IsGuest}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="16"
                Padding="36">

                <Border
                    StrokeShape="RoundRectangle 20"
                    Stroke="{StaticResource AppDivider}"
                    StrokeThickness="1.5"
                    HeightRequest="80"
                    WidthRequest="80"
                    HorizontalOptions="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFF4ED" Offset="0"/>
                            <GradientStop Color="#FFEDD5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackLayout
                        Orientation="Horizontal"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Spacing="5">
                        <Border StrokeShape="RoundRectangle 3" Stroke="Transparent" WidthRequest="16" HeightRequest="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#C2410C" Offset="0"/>
                                    <GradientStop Color="#EA580C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border StrokeShape="RoundRectangle 3" Stroke="Transparent" WidthRequest="16" HeightRequest="24">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FBBF24" Offset="0"/>
                                    <GradientStop Color="#F59E0B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </StackLayout>
                </Border>

                <Label
                    Text="Your Library Awaits"
                    FontFamily="OpenSansSemibold"
                    FontSize="22"
                    TextColor="{StaticResource AppNavy}"
                    HorizontalTextAlignment="Center"/>

                <Label
                    Text="Sign in to see the books you've purchased and start reading."
                    Style="{StaticResource BodyTextStyle}"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"/>

                <Button
                    Text="Sign In"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding NavigateToAuthCommand}"
                    Margin="0,8,0,0"/>

            </VerticalStackLayout>

            <!-- Authenticated state -->
            <Grid IsVisible="{Binding IsAuthenticated}">

                <!-- Loading spinner -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="{StaticResource AppOrange}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>

                <!-- Empty library state -->
                <VerticalStackLayout
                    IsVisible="{Binding ShowEmptyState}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="14"
                    Padding="40">

                    <Border
                        StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource AppDivider}"
                        StrokeThickness="1.5"
                        HeightRequest="80"
                        WidthRequest="80"
                        HorizontalOptions="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFF4ED" Offset="0"/>
                                <GradientStop Color="#FFEDD5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <BoxView
                            WidthRequest="28" HeightRequest="28"
                            CornerRadius="6"
                            BackgroundColor="{StaticResource AppNavy}"
                            Opacity="0.25"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Border>

                    <Label
                        Text="No books yet"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        Text="Books you purchase will appear here. Head to the Library to find something great."
                        Style="{StaticResource MutedTextStyle}"
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>

                </VerticalStackLayout>

                <!-- ── Books accordion list ─────────────────────── -->
                <ScrollView IsVisible="{Binding HasBooks}">
                    <VerticalStackLayout
                        x:Name="LibraryGroupsLayout"
                        Padding="16,16,16,32"
                        Spacing="10"
                        BindableLayout.ItemsSource="{Binding LibraryGroups}">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:LibraryBookGroup">

                                <Border
                                    StrokeShape="RoundRectangle 18"
                                    Stroke="{StaticResource AppDivider}"
                                    StrokeThickness="1"
                                    BackgroundColor="{StaticResource AppSurface}">
                                    <Border.Shadow>
                                        <Shadow Brush="{StaticResource AppNavyBrush}" Offset="0,3" Radius="12" Opacity="0.07"/>
                                    </Border.Shadow>

                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="0">

                                        <!-- Left accent bar (orange when expanded) -->
                                        <Border Grid.Column="0" StrokeShape="RoundRectangle 18,0,0,18" Stroke="Transparent">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsExpanded}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource AppNavy}"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsExpanded}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="Transparent"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="0">

                                            <!-- Book header row -->
                                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14">

                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding ToggleCommand}"/>
                                                </Grid.GestureRecognizers>

                                                <!-- Cover thumbnail — Border clips the cover image -->
                                                <Border
                                                    Grid.Column="0"
                                                    StrokeShape="RoundRectangle 10"
                                                    Stroke="Transparent"
                                                    WidthRequest="54"
                                                    HeightRequest="70"
                                                    Margin="0,0,14,0">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#7C2D12" Offset="0"/>
                                                            <GradientStop Color="#C2410C" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Grid>
                                                        <!-- Vector placeholder — page lines, shown when no cover -->
                                                        <VerticalStackLayout
                                                            Spacing="3.5"
                                                            HorizontalOptions="Center"
                                                            VerticalOptions="Center"
                                                            IsVisible="{Binding Book.ImageCoverUrl, Converter={x:StaticResource NullConverter}}">
                                                            <BoxView WidthRequest="28" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.55"/>
                                                            <BoxView WidthRequest="22" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.38"/>
                                                            <BoxView WidthRequest="26" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.50"/>
                                                            <BoxView WidthRequest="18" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.28"/>
                                                            <BoxView WidthRequest="24" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.45"/>
                                                        </VerticalStackLayout>
                                                        <!-- Cover image — clipped by parent Border -->
                                                        <Image
                                                            Source="{Binding Book.ImageCoverUrl, Converter={x:StaticResource ImageCoverConverter}}"
                                                            Aspect="AspectFill"
                                                            IsVisible="{Binding Book.ImageCoverUrl, Converter={x:StaticResource NotNullConverter}}"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Title + doc count -->
                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                                    <Label
                                                        Text="{Binding Label}"
                                                        FontFamily="OpenSansSemibold"
                                                        FontSize="15"
                                                        TextColor="{StaticResource AppNavy}"
                                                        LineBreakMode="WordWrap"/>
                                                    <HorizontalStackLayout Spacing="6">
                                                        <Border
                                                            StrokeShape="RoundRectangle 4"
                                                            Stroke="Transparent"
                                                            BackgroundColor="{StaticResource AppSurfaceVariant}"
                                                            Padding="7,3">
                                                            <Label
                                                                Text="{Binding DocCount, StringFormat='{0} docs'}"
                                                                FontFamily="OpenSansSemibold"
                                                                FontSize="10"
                                                                TextColor="{StaticResource AppNavy}"/>
                                                        </Border>
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>

                                                <!-- Chevron -->
                                                <Border
                                                    Grid.Column="2"
                                                    StrokeShape="Ellipse"
                                                    Stroke="{StaticResource AppDivider}"
                                                    WidthRequest="28"
                                                    HeightRequest="28"
                                                    VerticalOptions="Center"
                                                    Margin="8,0,0,0">
                                                    <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="BackgroundColor" Value="{StaticResource AppNavy}"/>
                                                            <Setter Property="Stroke" Value="Transparent"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding IsExpanded}" Value="False">
                                                            <Setter Property="BackgroundColor" Value="Transparent"/>
                                                        </DataTrigger>
                                                    </Border.Triggers>
                                                    <Label VerticalOptions="Center" HorizontalOptions="Center" FontSize="12" Margin="1,0,0,0">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Text" Value="▼"/>
                                                                <Setter Property="TextColor" Value="White"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Text" Value="▶"/>
                                                                <Setter Property="TextColor" Value="{StaticResource AppTextMuted}"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Border>

                                            </Grid>

                                            <!-- Divider -->
                                            <BoxView
                                                HeightRequest="1"
                                                BackgroundColor="{StaticResource AppDivider}"
                                                IsVisible="{Binding IsExpanded}"/>

                                            <!-- Documents list -->
                                            <VerticalStackLayout
                                                Spacing="0"
                                                IsVisible="{Binding IsExpanded}"
                                                BindableLayout.ItemsSource="{Binding DocItems}">

                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:DocItem">

                                                        <Grid
                                                            ColumnDefinitions="Auto,*,Auto"
                                                            Padding="14,12"
                                                            BackgroundColor="Transparent">

                                                            <Grid.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding OpenCommand}"/>
                                                            </Grid.GestureRecognizers>

                                                            <!-- Doc icon -->
                                                            <VerticalStackLayout
                                                                Grid.Column="0"
                                                                VerticalOptions="Center"
                                                                Spacing="2.5"
                                                                WidthRequest="16"
                                                                Margin="10,0,12,0">
                                                                <BoxView HeightRequest="2" CornerRadius="1" BackgroundColor="{StaticResource AppNavy}"/>
                                                                <BoxView HeightRequest="2" CornerRadius="1" BackgroundColor="{StaticResource AppNavy}" Opacity="0.6"/>
                                                                <BoxView HeightRequest="2" CornerRadius="1" BackgroundColor="{StaticResource AppNavy}" Opacity="0.35"/>
                                                            </VerticalStackLayout>

                                                            <!-- Doc title -->
                                                            <Label
                                                                Grid.Column="1"
                                                                Text="{Binding DisplayTitle}"
                                                                FontFamily="OpenSansRegular"
                                                                FontSize="13"
                                                                TextColor="{StaticResource AppTextPrimary}"
                                                                VerticalOptions="Center"/>

                                                            <!-- Read CTA -->
                                                            <Border
                                                                Grid.Column="2"
                                                                StrokeShape="RoundRectangle 8"
                                                                Stroke="Transparent"
                                                                BackgroundColor="{StaticResource AppSurfaceVariant}"
                                                                Padding="10,5"
                                                                VerticalOptions="Center"
                                                                Margin="8,0,4,0">
                                                                <Label
                                                                    Text="Read →"
                                                                    FontFamily="OpenSansSemibold"
                                                                    FontSize="11"
                                                                    TextColor="{StaticResource AppNavy}"/>
                                                            </Border>

                                                        </Grid>

                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>

                                            </VerticalStackLayout>

                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>

                            </DataTemplate>
                        </BindableLayout.ItemTemplate>

                    </VerticalStackLayout>
                </ScrollView>

            </Grid>

            <!-- Error snackbar -->
            <Border
                IsVisible="{Binding HasError}"
                BackgroundColor="{StaticResource AppError}"
                StrokeShape="RoundRectangle 12"
                Stroke="Transparent"
                Padding="16,12"
                Margin="16,0,16,24"
                VerticalOptions="End">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="White"
                    FontSize="13"
                    HorizontalTextAlignment="Center"/>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
