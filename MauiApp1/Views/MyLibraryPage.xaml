<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.MyLibraryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    xmlns:models="clr-namespace:LogicLib1.Models.App;assembly=LogicLib1"
    x:DataType="vm:MyLibraryViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Custom header -->
        <Grid
            Grid.Row="0"
            BackgroundColor="{StaticResource AppNavy}"
            Padding="20,52,20,24">
            <Label
                Text="My Library"
                TextColor="White"
                FontFamily="OpenSansSemibold"
                FontSize="26"/>
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">

            <!-- Guest state -->
            <VerticalStackLayout
                IsVisible="{Binding IsGuest}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="16"
                Padding="36">

                <Border
                    BackgroundColor="{StaticResource AppSurfaceVariant}"
                    StrokeShape="Ellipse"
                    Stroke="Transparent"
                    HeightRequest="96"
                    WidthRequest="96"
                    HorizontalOptions="Center">
                    <Label
                        Text="📖"
                        FontSize="44"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

                <Label
                    Text="Your Library Awaits"
                    FontFamily="OpenSansSemibold"
                    FontSize="22"
                    TextColor="{StaticResource AppNavy}"
                    HorizontalTextAlignment="Center"/>

                <Label
                    Text="Sign in to see the books you've purchased and start reading."
                    Style="{StaticResource BodyTextStyle}"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"/>

                <Button
                    Text="Sign In"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding NavigateToAuthCommand}"
                    Margin="0,8,0,0"/>

            </VerticalStackLayout>

            <!-- Authenticated state -->
            <Grid IsVisible="{Binding IsAuthenticated}">

                <!-- Loading spinner -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>

                <!-- Empty library state -->
                <VerticalStackLayout
                    IsVisible="{Binding HasBooks, Converter={x:StaticResource InverseBoolConverter}}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="14"
                    Padding="40">

                    <Border
                        BackgroundColor="{StaticResource AppSurfaceVariant}"
                        StrokeShape="Ellipse"
                        Stroke="Transparent"
                        HeightRequest="96"
                        WidthRequest="96"
                        HorizontalOptions="Center">
                        <Label
                            Text="📦"
                            FontSize="44"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Border>

                    <Label
                        Text="No books yet"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        Text="Books you purchase will appear here. Head to the Library to find something great."
                        Style="{StaticResource MutedTextStyle}"
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>

                </VerticalStackLayout>

                <!-- Books grid -->
                <CollectionView
                    ItemsSource="{Binding PurchasedBooks}"
                    IsVisible="{Binding HasBooks}"
                    Margin="14,14,14,0">

                    <CollectionView.ItemsLayout>
                        <GridItemsLayout
                            Orientation="Vertical"
                            Span="2"
                            HorizontalItemSpacing="10"
                            VerticalItemSpacing="12"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BookMetadata">
                            <Border Style="{StaticResource CardStyle}" Margin="0">
                                <Grid RowDefinitions="160,Auto">

                                    <Border
                                        Grid.Row="0"
                                        BackgroundColor="{StaticResource AppSurfaceVariant}"
                                        StrokeShape="RoundRectangle 12,12,0,0"
                                        Stroke="Transparent"
                                        StrokeThickness="0">
                                        <Grid>
                                            <Image Source="{Binding ImageCoverUrl}" Aspect="AspectFill"
                                                   IsVisible="{Binding ImageCoverUrl, Converter={x:StaticResource NotNullConverter}}"/>
                                            <Label
                                                Text="📚"
                                                FontSize="36"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                Opacity="0.4"
                                                IsVisible="{Binding ImageCoverUrl, Converter={x:StaticResource NullConverter}}"/>
                                        </Grid>
                                    </Border>

                                    <VerticalStackLayout Grid.Row="1" Padding="12,10,12,12" Spacing="4">
                                        <Label
                                            Text="{Binding Title}"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="13"
                                            TextColor="{StaticResource AppTextPrimary}"
                                            MaxLines="2"
                                            LineBreakMode="TailTruncation"/>
                                        <Label
                                            Text="{Binding Category}"
                                            Style="{StaticResource MutedTextStyle}"
                                            FontSize="11"
                                            Margin="0,0,0,4"/>
                                        <Button
                                            Text="Read"
                                            Style="{StaticResource SmallPrimaryButtonStyle}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ReadCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </Grid>

            <!-- Error snackbar -->
            <Border
                IsVisible="{Binding HasError}"
                BackgroundColor="{StaticResource AppError}"
                StrokeShape="RoundRectangle 12"
                Stroke="Transparent"
                Padding="16,12"
                Margin="16,0,16,24"
                VerticalOptions="End">
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="White"
                    FontSize="13"
                    HorizontalTextAlignment="Center"/>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
