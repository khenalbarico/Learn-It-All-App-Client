<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:AccountViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Gradient header ────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                    <GradientStop Color="#7C2D12" Offset="0.0"/>
                    <GradientStop Color="#C2410C" Offset="0.5"/>
                    <GradientStop Color="#EA580C" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Amber orb — top right -->
            <Border
                HeightRequest="180" WidthRequest="180"
                StrokeShape="Ellipse" Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,-60,-70,0" InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#40FBBF24" Offset="0.0"/>
                        <GradientStop Color="#00FBBF24" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- Orange glow — bottom left -->
            <Border
                HeightRequest="100" WidthRequest="100"
                StrokeShape="Ellipse" Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="Start" VerticalOptions="End"
                Margin="-30,0,0,-20" InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#38F97316" Offset="0.0"/>
                        <GradientStop Color="#00F97316" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <VerticalStackLayout Padding="20,52,20,28" Spacing="4">
                <Label
                    Text="Account"
                    TextColor="White"
                    FontFamily="OpenSansSemibold"
                    FontSize="28"/>
                <Label
                    Text="Manage your profile and settings"
                    TextColor="White"
                    Opacity="0.7"
                    FontFamily="OpenSansRegular"
                    FontSize="13"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Content ────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <Grid>

                <!-- Guest state -->
                <VerticalStackLayout
                    IsVisible="{Binding IsGuest}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="16"
                    Padding="36"
                    Margin="0,40,0,0">

                    <Border
                        StrokeShape="Ellipse"
                        Stroke="{StaticResource AppDivider}"
                        StrokeThickness="2"
                        HeightRequest="88"
                        WidthRequest="88"
                        HorizontalOptions="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFF4ED" Offset="0"/>
                                <GradientStop Color="#FFEDD5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                            <Border StrokeShape="Ellipse" Stroke="Transparent" BackgroundColor="{StaticResource AppNavy}" Opacity="0.45" HeightRequest="22" WidthRequest="22" HorizontalOptions="Center"/>
                            <Border StrokeShape="RoundRectangle 5,5,0,0" Stroke="Transparent" BackgroundColor="{StaticResource AppNavy}" Opacity="0.35" HeightRequest="16" WidthRequest="36" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Label
                        Text="Sign In to Your Account"
                        FontFamily="OpenSansSemibold"
                        FontSize="22"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        Text="Access your profile, subscription details, and account settings."
                        Style="{StaticResource BodyTextStyle}"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>

                    <Button
                        Text="Sign In"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NavigateToAuthCommand}"
                        Margin="0,8,0,0"/>

                </VerticalStackLayout>

                <!-- Authenticated state -->
                <VerticalStackLayout IsVisible="{Binding IsAuthenticated}" Spacing="0">

                    <!-- ── Profile hero card (orange gradient) ──── -->
                    <Border
                        StrokeShape="RoundRectangle 0,0,28,28"
                        Stroke="Transparent"
                        Margin="16,20,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                                <GradientStop Color="#7C2D12" Offset="0.0"/>
                                <GradientStop Color="#C2410C" Offset="0.5"/>
                                <GradientStop Color="#EA580C" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource AppNavyBrush}" Offset="0,6" Radius="24" Opacity="0.22"/>
                        </Border.Shadow>

                        <Grid Padding="24,28,24,28">

                            <!-- Amber orb inside card -->
                            <Border
                                HeightRequest="100" WidthRequest="100"
                                StrokeShape="Ellipse" Stroke="Transparent" StrokeThickness="0"
                                HorizontalOptions="End" VerticalOptions="Start"
                                Margin="0,-20,-20,0" InputTransparent="True">
                                <Border.Background>
                                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                                        <GradientStop Color="#35FBBF24" Offset="0.0"/>
                                        <GradientStop Color="#00FBBF24" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>

                            <VerticalStackLayout HorizontalOptions="Center" Spacing="12">

                                <!-- Avatar with glow ring -->
                                <Grid HorizontalOptions="Center">
                                    <!-- Glow ring -->
                                    <Border
                                        StrokeShape="Ellipse"
                                        Stroke="Transparent"
                                        HeightRequest="100"
                                        WidthRequest="100"
                                        HorizontalOptions="Center">
                                        <Border.Background>
                                            <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                                                <GradientStop Color="#60FBBF24" Offset="0.3"/>
                                                <GradientStop Color="#00FBBF24" Offset="1.0"/>
                                            </RadialGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <!-- Avatar circle -->
                                    <Border
                                        StrokeShape="Ellipse"
                                        Stroke="White"
                                        StrokeThickness="3"
                                        HeightRequest="84"
                                        WidthRequest="84"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F97316" Offset="0"/>
                                                <GradientStop Color="#C2410C" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Label
                                            Text="{Binding DisplayName[0], StringFormat='{0}'}"
                                            TextColor="White"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="34"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"/>
                                    </Border>
                                </Grid>

                                <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label
                                        Text="{Binding DisplayName}"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="20"
                                        TextColor="White"
                                        HorizontalTextAlignment="Center"/>
                                    <Label
                                        Text="{Binding UserInfo.Email}"
                                        TextColor="White"
                                        Opacity="0.65"
                                        FontFamily="OpenSansRegular"
                                        FontSize="13"
                                        HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <!-- Subscription badge -->
                                <Border
                                    StrokeShape="RoundRectangle 20"
                                    Stroke="#40FFFFFF"
                                    StrokeThickness="1"
                                    BackgroundColor="#20FFFFFF"
                                    Padding="18,7"
                                    HorizontalOptions="Center">
                                    <Label
                                        Text="{Binding SubscriptionLabel}"
                                        TextColor="White"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="12"/>
                                </Border>

                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- ── Profile info rows ────────────────────── -->
                    <VerticalStackLayout Padding="20,24,20,0" Spacing="10">

                        <HorizontalStackLayout Spacing="10" Margin="0,0,0,2">
                            <Border
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource AppOrange}"
                                Padding="10,4">
                                <Label
                                    Text="PROFILE INFO"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="11"
                                    CharacterSpacing="1.4"/>
                            </Border>
                        </HorizontalStackLayout>

                        <!-- Name card -->
                        <Border Style="{StaticResource CardStyle}" Padding="18,16">
                            <Grid ColumnDefinitions="*,*">
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label Text="FIRST NAME" Style="{StaticResource MutedTextStyle}" FontSize="10" CharacterSpacing="0.8"/>
                                    <Label Text="{Binding UserInfo.FirstName}" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource AppNavy}"/>
                                </VerticalStackLayout>
                                <BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="{StaticResource AppDivider}" HorizontalOptions="End" VerticalOptions="Fill" Margin="0,4"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="3" Margin="16,0,0,0">
                                    <Label Text="LAST NAME" Style="{StaticResource MutedTextStyle}" FontSize="10" CharacterSpacing="0.8"/>
                                    <Label Text="{Binding UserInfo.LastName}" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource AppNavy}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Phone card (blue icon — minor accent) -->
                        <Border Style="{StaticResource CardStyle}" Padding="18,16">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border
                                    Grid.Column="0"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1E40AF" Offset="0"/>
                                            <GradientStop Color="#2563EB" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Label Text="☎" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="PHONE NUMBER" Style="{StaticResource MutedTextStyle}" FontSize="10" CharacterSpacing="0.8"/>
                                    <Label Text="{Binding UserInfo.PhoneNumber}" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource AppNavy}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <!-- Email card (orange icon) -->
                        <Border Style="{StaticResource CardStyle}" Padding="18,16">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border
                                    Grid.Column="0"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#C2410C" Offset="0"/>
                                            <GradientStop Color="#F97316" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Label Text="@" FontSize="16" FontFamily="OpenSansSemibold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="EMAIL ADDRESS" Style="{StaticResource MutedTextStyle}" FontSize="10" CharacterSpacing="0.8"/>
                                    <Label Text="{Binding UserInfo.Email}" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource AppNavy}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Label
                            Text="{Binding ErrorMessage}"
                            Style="{StaticResource ErrorTextStyle}"
                            IsVisible="{Binding HasError}"
                            Margin="0,4,0,0"/>

                        <Button
                            Text="Sign Out"
                            Style="{StaticResource OutlineButtonStyle}"
                            Command="{Binding SignOutCommand}"
                            Margin="0,16,0,36"/>

                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!-- Loading overlay -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="{StaticResource AppOrange}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Margin="0,80,0,0"/>

            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
