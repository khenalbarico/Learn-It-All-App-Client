<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:AccountViewModel"
    Title="Account"
    BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <Grid Padding="0">

            <!-- Guest state -->
            <VerticalStackLayout
                IsVisible="{Binding IsGuest}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="16"
                Padding="40"
                Margin="0,80,0,0">

                <Image
                    Source="app_logo.png"
                    HeightRequest="88"
                    WidthRequest="88"
                    Aspect="AspectFit"
                    HorizontalOptions="Center"
                    Opacity="0.5"/>

                <Label
                    Text="Sign In to Your Account"
                    Style="{StaticResource PageTitleStyle}"
                    FontSize="22"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"/>

                <Label
                    Text="Access your profile, subscription, and account settings."
                    Style="{StaticResource BodyTextStyle}"
                    HorizontalTextAlignment="Center"/>

                <Button
                    Text="Sign In"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding NavigateToAuthCommand}"
                    Margin="0,8,0,0"/>

            </VerticalStackLayout>

            <!-- Authenticated state -->
            <VerticalStackLayout
                IsVisible="{Binding IsAuthenticated}"
                Spacing="0">

                <!-- Profile header card -->
                <Grid
                    BackgroundColor="{StaticResource AppNavy}"
                    Padding="24,48,24,32">

                    <VerticalStackLayout HorizontalOptions="Center" Spacing="10">

                        <!-- Avatar circle -->
                        <Border
                            BackgroundColor="{StaticResource AppOrange}"
                            StrokeShape="Ellipse"
                            Stroke="Transparent"
                            HeightRequest="72"
                            WidthRequest="72"
                            HorizontalOptions="Center">
                            <Label
                                Text="{Binding DisplayName[0], StringFormat='{0}'}"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="28"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Border>

                        <Label
                            Text="{Binding DisplayName}"
                            Style="{StaticResource OnDarkTitleStyle}"
                            FontSize="20"/>

                        <Label
                            Text="{Binding UserInfo.Email}"
                            Style="{StaticResource OnDarkLabelStyle}"
                            FontSize="13"
                            Opacity="0.75"
                            HorizontalTextAlignment="Center"/>

                        <!-- Subscription badge -->
                        <Border
                            BackgroundColor="{StaticResource AppOrange}"
                            StrokeShape="RoundRectangle 20"
                            Stroke="Transparent"
                            Padding="14,6"
                            HorizontalOptions="Center">
                            <Label
                                Text="{Binding SubscriptionLabel}"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="12"/>
                        </Border>

                    </VerticalStackLayout>
                </Grid>

                <!-- Info section -->
                <VerticalStackLayout Padding="20,20,20,0" Spacing="12">

                    <Label Text="PROFILE INFO" Style="{StaticResource MutedTextStyle}" FontFamily="OpenSansSemibold" FontSize="11" Margin="0,0,0,4"/>

                    <!-- First name -->
                    <Border Style="{StaticResource CardStyle}" Padding="16,14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="First Name" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                                <Label Text="{Binding UserInfo.FirstName}" FontFamily="OpenSansSemibold" FontSize="15"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Last name -->
                    <Border Style="{StaticResource CardStyle}" Padding="16,14">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Last Name" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                            <Label Text="{Binding UserInfo.LastName}" FontFamily="OpenSansSemibold" FontSize="15"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Phone -->
                    <Border Style="{StaticResource CardStyle}" Padding="16,14">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Phone Number" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                            <Label Text="{Binding UserInfo.PhoneNumber}" FontFamily="OpenSansSemibold" FontSize="15"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Email -->
                    <Border Style="{StaticResource CardStyle}" Padding="16,14">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Email" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                            <Label Text="{Binding UserInfo.Email}" FontFamily="OpenSansSemibold" FontSize="15"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Error -->
                    <Label
                        Text="{Binding ErrorMessage}"
                        Style="{StaticResource ErrorTextStyle}"
                        IsVisible="{Binding HasError}"
                        Margin="0,4,0,0"/>

                    <!-- Sign out -->
                    <Button
                        Text="Sign Out"
                        Style="{StaticResource OutlineButtonStyle}"
                        Command="{Binding SignOutCommand}"
                        Margin="0,16,0,32"/>

                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- Loading overlay -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                HorizontalOptions="Center"/>

        </Grid>
    </ScrollView>

</ContentPage>
