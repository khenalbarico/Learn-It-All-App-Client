<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.AccountPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:AccountViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Gradient header ────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                    <GradientStop Color="#0D1830" Offset="0.0"/>
                    <GradientStop Color="#1A3660" Offset="0.5"/>
                    <GradientStop Color="#2A5298" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Decorative orb — top right -->
            <Border
                HeightRequest="160" WidthRequest="160"
                StrokeShape="Ellipse"
                Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,-50,-60,0"
                InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#403A78D0" Offset="0.0"/>
                        <GradientStop Color="#002A5298" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <VerticalStackLayout Padding="20,52,20,28" Spacing="4">
                <Label
                    Text="Account"
                    TextColor="White"
                    FontFamily="OpenSansSemibold"
                    FontSize="26"/>
                <Label
                    Text="Manage your profile and settings"
                    TextColor="White"
                    Opacity="0.65"
                    FontFamily="OpenSansRegular"
                    FontSize="13"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Content ────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <Grid>

                <!-- Guest state -->
                <VerticalStackLayout
                    IsVisible="{Binding IsGuest}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="16"
                    Padding="36"
                    Margin="0,32,0,0">

                    <!-- Person icon -->
                    <Border
                        StrokeShape="Ellipse"
                        Stroke="#DDE4F0"
                        StrokeThickness="1.5"
                        HeightRequest="80"
                        WidthRequest="80"
                        HorizontalOptions="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EEF2F8" Offset="0"/>
                                <GradientStop Color="#D8E4F4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                            <Border
                                StrokeShape="Ellipse"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource AppBlue}"
                                Opacity="0.5"
                                HeightRequest="20"
                                WidthRequest="20"
                                HorizontalOptions="Center"/>
                            <Border
                                StrokeShape="RoundRectangle 4,4,0,0"
                                Stroke="Transparent"
                                BackgroundColor="{StaticResource AppBlue}"
                                Opacity="0.4"
                                HeightRequest="14"
                                WidthRequest="32"
                                HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Label
                        Text="Sign In to Your Account"
                        FontFamily="OpenSansSemibold"
                        FontSize="22"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>

                    <Label
                        Text="Access your profile, subscription details, and account settings."
                        Style="{StaticResource BodyTextStyle}"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>

                    <Button
                        Text="Sign In"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NavigateToAuthCommand}"
                        Margin="0,8,0,0"/>

                </VerticalStackLayout>

                <!-- Authenticated state -->
                <VerticalStackLayout IsVisible="{Binding IsAuthenticated}" Spacing="0">

                    <!-- Profile hero card -->
                    <Grid>
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EEF2F8" Offset="0"/>
                                <GradientStop Color="#D8E4F4" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Padding="24,28,24,28">

                            <!-- Avatar circle (orange gradient with initial) -->
                            <Border
                                StrokeShape="Ellipse"
                                Stroke="White"
                                StrokeThickness="3"
                                HeightRequest="80"
                                WidthRequest="80"
                                HorizontalOptions="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F5A623" Offset="0"/>
                                        <GradientStop Color="#D4890F" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label
                                    Text="{Binding DisplayName[0], StringFormat='{0}'}"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="32"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            </Border>

                            <Label
                                Text="{Binding DisplayName}"
                                FontFamily="OpenSansSemibold"
                                FontSize="20"
                                TextColor="{StaticResource AppNavy}"
                                HorizontalTextAlignment="Center"/>

                            <Label
                                Text="{Binding UserInfo.Email}"
                                Style="{StaticResource MutedTextStyle}"
                                FontSize="13"
                                HorizontalTextAlignment="Center"/>

                            <!-- Subscription badge -->
                            <Border
                                StrokeShape="RoundRectangle 20"
                                Stroke="Transparent"
                                Padding="16,6"
                                HorizontalOptions="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1A3660" Offset="0"/>
                                        <GradientStop Color="#2A5298" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label
                                    Text="{Binding SubscriptionLabel}"
                                    TextColor="White"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="12"/>
                            </Border>

                        </VerticalStackLayout>
                    </Grid>

                    <!-- Profile info rows -->
                    <VerticalStackLayout Padding="20,20,20,0" Spacing="10">

                        <Label
                            Text="PROFILE INFO"
                            Style="{StaticResource MutedTextStyle}"
                            FontFamily="OpenSansSemibold"
                            FontSize="11"
                            CharacterSpacing="1.2"
                            Margin="0,0,0,2"/>

                        <Border Style="{StaticResource CardStyle}" Padding="16,14">
                            <Grid ColumnDefinitions="*,*">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="First Name" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                                    <Label Text="{Binding UserInfo.FirstName}" FontFamily="OpenSansSemibold" FontSize="15"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="Last Name" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                                    <Label Text="{Binding UserInfo.LastName}" FontFamily="OpenSansSemibold" FontSize="15"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Padding="16,14">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Phone Number" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                                <Label Text="{Binding UserInfo.PhoneNumber}" FontFamily="OpenSansSemibold" FontSize="15"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Padding="16,14">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Email Address" Style="{StaticResource MutedTextStyle}" FontSize="11"/>
                                <Label Text="{Binding UserInfo.Email}" FontFamily="OpenSansSemibold" FontSize="15"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Error -->
                        <Label
                            Text="{Binding ErrorMessage}"
                            Style="{StaticResource ErrorTextStyle}"
                            IsVisible="{Binding HasError}"
                            Margin="0,4,0,0"/>

                        <!-- Sign out -->
                        <Button
                            Text="Sign Out"
                            Style="{StaticResource OutlineButtonStyle}"
                            Command="{Binding SignOutCommand}"
                            Margin="0,16,0,32"/>

                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!-- Loading overlay -->
                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    IsVisible="{Binding IsBusy}"
                    Color="{StaticResource AppOrange}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Margin="0,80,0,0"/>

            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
