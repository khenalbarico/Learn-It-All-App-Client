<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.PdfViewerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:PdfViewerViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Gradient header ─────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                    <GradientStop Color="#7C2D12" Offset="0.0"/>
                    <GradientStop Color="#C2410C" Offset="0.5"/>
                    <GradientStop Color="#EA580C" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Amber orb — top right -->
            <Border
                HeightRequest="120" WidthRequest="120"
                StrokeShape="Ellipse"
                Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,-40,-40,0"
                InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#30FBBF24" Offset="0.0"/>
                        <GradientStop Color="#00FBBF24" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <Grid ColumnDefinitions="Auto,*,Auto" Padding="8,48,8,12">

                <Button
                    Grid.Column="0"
                    Text="‹"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    FontFamily="OpenSansSemibold"
                    FontSize="28"
                    Padding="12,0,8,0"
                    MinimumWidthRequest="44"
                    VerticalOptions="Center"
                    Command="{Binding GoBackCommand}"/>

                <VerticalStackLayout
                    Grid.Column="1"
                    VerticalOptions="Center"
                    Spacing="2">
                    <Label
                        Text="{Binding BookTitle}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        MaxLines="1"
                        LineBreakMode="TailTruncation"/>
                    <Label
                        Text="{Binding DocTitle}"
                        TextColor="White"
                        Opacity="0.65"
                        FontFamily="OpenSansRegular"
                        FontSize="11"
                        MaxLines="1"
                        LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>

                <!-- Switch button -->
                <Border
                    Grid.Column="2"
                    StrokeShape="RoundRectangle 10"
                    Stroke="#40FFFFFF"
                    StrokeThickness="1"
                    BackgroundColor="#20FFFFFF"
                    Padding="10,7"
                    VerticalOptions="Center"
                    Margin="6,0,8,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding TogglePanelCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                            <BoxView WidthRequest="14" HeightRequest="2" CornerRadius="1" BackgroundColor="White"/>
                            <BoxView WidthRequest="10" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.7"/>
                            <BoxView WidthRequest="12" HeightRequest="2" CornerRadius="1" BackgroundColor="White" Opacity="0.5"/>
                        </VerticalStackLayout>
                        <Label
                            Text="Switch"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="12"
                            VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

            </Grid>
        </Grid>

        <!-- ── Content area ───────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- PDF WebView -->
            <WebView
                x:Name="PdfWebView"
                IsVisible="{Binding IsReady}"
                Navigated="OnWebViewNavigated"
                Navigating="OnWebViewNavigating"/>

            <!-- Loading state -->
            <VerticalStackLayout
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="20"
                Padding="40">

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    Color="{StaticResource AppNavy}"
                    WidthRequest="52"
                    HeightRequest="52"
                    HorizontalOptions="Center"/>

                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label
                        Text="Opening document..."
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>
                    <Label
                        Text="This may take a moment"
                        FontFamily="OpenSansRegular"
                        FontSize="13"
                        TextColor="{StaticResource AppTextMuted}"
                        HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- Error state -->
            <VerticalStackLayout
                IsVisible="{Binding HasError}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="20"
                Padding="40">

                <Border
                    StrokeShape="RoundRectangle 20"
                    Stroke="#FFD0D0"
                    StrokeThickness="1.5"
                    HeightRequest="80"
                    WidthRequest="80"
                    HorizontalOptions="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFF5F5" Offset="0"/>
                            <GradientStop Color="#FFE5E5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label
                        Text="!"
                        FontFamily="OpenSansSemibold"
                        FontSize="38"
                        TextColor="{StaticResource AppError}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Unable to Load"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>
                    <Label
                        Text="{Binding ErrorMessage}"
                        FontFamily="OpenSansRegular"
                        FontSize="14"
                        TextColor="{StaticResource AppTextSecondary}"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>
                </VerticalStackLayout>

                <Button
                    Text="Go Back"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,4,0,0"
                    Command="{Binding GoBackCommand}"/>

            </VerticalStackLayout>

            <!-- ── Switcher overlay ──────────────────────────────── -->
            <Grid x:Name="PanelOverlay" IsVisible="False">

                <!-- Dim backdrop -->
                <BoxView BackgroundColor="#70000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOverlayTapped"/>
                    </BoxView.GestureRecognizers>
                </BoxView>

                <!-- Slide-up panel -->
                <Border
                    x:Name="SwitcherPanel"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource AppSurface}"
                    VerticalOptions="End">

                    <Grid RowDefinitions="Auto,Auto,Auto">

                        <!-- Handle + title -->
                        <VerticalStackLayout Grid.Row="0" Padding="20,14,20,10" Spacing="0">
                            <BoxView
                                WidthRequest="40" HeightRequest="4"
                                CornerRadius="2"
                                BackgroundColor="{StaticResource AppDivider}"
                                HorizontalOptions="Center"
                                Margin="0,0,0,14"/>
                            <Label
                                Text="Switch Document or Book"
                                FontFamily="OpenSansSemibold"
                                FontSize="17"
                                TextColor="{StaticResource AppNavy}"/>
                            <Label
                                Text="Tap any document below to open it"
                                FontFamily="OpenSansRegular"
                                FontSize="12"
                                TextColor="{StaticResource AppTextMuted}"
                                Margin="0,2,0,0"/>
                        </VerticalStackLayout>

                        <BoxView Grid.Row="1" HeightRequest="1" BackgroundColor="{StaticResource AppDivider}"/>

                        <!-- Books + docs accordion -->
                        <ScrollView Grid.Row="2" MaximumHeightRequest="460">
                            <VerticalStackLayout
                                Padding="16,12,16,28"
                                Spacing="8"
                                BindableLayout.ItemsSource="{Binding BookGroups}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PdfBookGroup">

                                        <Border StrokeShape="RoundRectangle 14" StrokeThickness="2">

                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsCurrentBook}" Value="True">
                                                    <Setter Property="Stroke" Value="{StaticResource AppNavy}"/>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource AppSurfaceVariant}"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsCurrentBook}" Value="False">
                                                    <Setter Property="Stroke" Value="{StaticResource AppDivider}"/>
                                                    <Setter Property="BackgroundColor" Value="{StaticResource AppSurface}"/>
                                                </DataTrigger>
                                            </Border.Triggers>

                                            <VerticalStackLayout Spacing="0">

                                                <!-- Book header -->
                                                <Grid ColumnDefinitions="*,Auto" Padding="14,12">
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding ToggleCommand}"/>
                                                    </Grid.GestureRecognizers>

                                                    <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                                        <Border
                                                            IsVisible="{Binding IsCurrentBook}"
                                                            BackgroundColor="{StaticResource AppBlue}"
                                                            StrokeShape="RoundRectangle 4"
                                                            Stroke="Transparent"
                                                            Padding="6,2"
                                                            HorizontalOptions="Start">
                                                            <Label
                                                                Text="NOW READING"
                                                                TextColor="White"
                                                                FontFamily="OpenSansSemibold"
                                                                FontSize="8"/>
                                                        </Border>
                                                        <Label
                                                            Text="{Binding Label}"
                                                            FontFamily="OpenSansSemibold"
                                                            FontSize="14"
                                                            TextColor="{StaticResource AppNavy}"
                                                            LineBreakMode="WordWrap"/>
                                                    </VerticalStackLayout>

                                                    <Label
                                                        Grid.Column="1"
                                                        Text="▶"
                                                        FontSize="14"
                                                        TextColor="{StaticResource AppTextMuted}"
                                                        VerticalOptions="Center"
                                                        Margin="10,0,0,0">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                                                <Setter Property="Text" Value="▼"/>
                                                                <Setter Property="TextColor" Value="{StaticResource AppNavy}"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Grid>

                                                <BoxView HeightRequest="1" BackgroundColor="{StaticResource AppDivider}" IsVisible="{Binding IsExpanded}"/>

                                                <!-- Document rows -->
                                                <VerticalStackLayout
                                                    Spacing="0"
                                                    IsVisible="{Binding IsExpanded}"
                                                    BindableLayout.ItemsSource="{Binding Docs}">

                                                    <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:PdfDocItem">

                                                            <Grid
                                                                ColumnDefinitions="Auto,*,Auto"
                                                                Padding="14,11"
                                                                BackgroundColor="Transparent">

                                                                <Grid.GestureRecognizers>
                                                                    <TapGestureRecognizer Command="{Binding OpenCommand}"/>
                                                                </Grid.GestureRecognizers>

                                                                <BoxView
                                                                    Grid.Column="0"
                                                                    WidthRequest="7" HeightRequest="7"
                                                                    CornerRadius="4"
                                                                    VerticalOptions="Center"
                                                                    Margin="0,0,12,0">
                                                                    <BoxView.Triggers>
                                                                        <DataTrigger TargetType="BoxView" Binding="{Binding IsCurrent}" Value="True">
                                                                            <Setter Property="BackgroundColor" Value="{StaticResource AppNavy}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="BoxView" Binding="{Binding IsCurrent}" Value="False">
                                                                            <Setter Property="BackgroundColor" Value="{StaticResource AppDivider}"/>
                                                                        </DataTrigger>
                                                                    </BoxView.Triggers>
                                                                </BoxView>

                                                                <Label
                                                                    Grid.Column="1"
                                                                    Text="{Binding DisplayTitle}"
                                                                    FontFamily="OpenSansRegular"
                                                                    FontSize="13"
                                                                    VerticalOptions="Center">
                                                                    <Label.Triggers>
                                                                        <DataTrigger TargetType="Label" Binding="{Binding IsCurrent}" Value="True">
                                                                            <Setter Property="FontFamily" Value="OpenSansSemibold"/>
                                                                            <Setter Property="TextColor" Value="{StaticResource AppNavy}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Label" Binding="{Binding IsCurrent}" Value="False">
                                                                            <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}"/>
                                                                        </DataTrigger>
                                                                    </Label.Triggers>
                                                                </Label>

                                                                <Label
                                                                    Grid.Column="2"
                                                                    Text="Reading"
                                                                    FontFamily="OpenSansSemibold"
                                                                    FontSize="11"
                                                                    TextColor="{StaticResource AppBlue}"
                                                                    VerticalOptions="Center"
                                                                    Margin="8,0,0,0"
                                                                    IsVisible="{Binding IsCurrent}"/>

                                                            </Grid>

                                                        </DataTemplate>
                                                    </BindableLayout.ItemTemplate>

                                                </VerticalStackLayout>

                                            </VerticalStackLayout>
                                        </Border>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>

                            </VerticalStackLayout>
                        </ScrollView>

                    </Grid>
                </Border>

            </Grid>

        </Grid>
    </Grid>
</ContentPage>
