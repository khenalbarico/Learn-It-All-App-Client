<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.PdfViewerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    xmlns:models="clr-namespace:LogicLib1.Models.App;assembly=LogicLib1"
    x:DataType="vm:PdfViewerViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Gradient header ─────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                    <GradientStop Color="#0D1830" Offset="0.0"/>
                    <GradientStop Color="#1A3660" Offset="0.5"/>
                    <GradientStop Color="#2A5298" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border
                HeightRequest="120" WidthRequest="120"
                StrokeShape="Ellipse"
                Stroke="Transparent" StrokeThickness="0"
                HorizontalOptions="End" VerticalOptions="Start"
                Margin="0,-40,-40,0"
                InputTransparent="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#30F5A623" Offset="0.0"/>
                        <GradientStop Color="#00F5A623" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <Grid ColumnDefinitions="Auto,*,Auto" Padding="8,48,8,12">

                <Button
                    Grid.Column="0"
                    Text="‹"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    FontFamily="OpenSansSemibold"
                    FontSize="28"
                    Padding="12,0,8,0"
                    MinimumWidthRequest="44"
                    VerticalOptions="Center"
                    Command="{Binding GoBackCommand}"/>

                <VerticalStackLayout
                    Grid.Column="1"
                    VerticalOptions="Center"
                    Spacing="2">
                    <Label
                        Text="{Binding BookTitle}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        MaxLines="1"
                        LineBreakMode="TailTruncation"/>
                    <Label
                        Text="Reading now"
                        TextColor="White"
                        Opacity="0.55"
                        FontFamily="OpenSansRegular"
                        FontSize="11"/>
                </VerticalStackLayout>

                <!-- My Books toggle button -->
                <Border
                    Grid.Column="2"
                    StrokeShape="RoundRectangle 10"
                    Stroke="#40FFFFFF"
                    StrokeThickness="1"
                    BackgroundColor="#20FFFFFF"
                    Padding="10,7"
                    VerticalOptions="Center"
                    Margin="6,0,8,0"
                    IsVisible="{Binding HasMultipleBooks}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleLibraryPanelCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                        <BoxView
                            WidthRequest="3" HeightRequest="12"
                            CornerRadius="2"
                            BackgroundColor="White"/>
                        <BoxView
                            WidthRequest="3" HeightRequest="16"
                            CornerRadius="2"
                            BackgroundColor="White" Opacity="0.75"/>
                        <BoxView
                            WidthRequest="3" HeightRequest="10"
                            CornerRadius="2"
                            BackgroundColor="White" Opacity="0.5"/>
                        <Label
                            Text="Books"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="12"
                            VerticalOptions="Center"
                            Margin="2,0,0,0"/>
                    </HorizontalStackLayout>
                </Border>

            </Grid>
        </Grid>

        <!-- ── Content area ───────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- PDF WebView -->
            <WebView
                x:Name="PdfWebView"
                IsVisible="{Binding IsReady}"
                Navigated="OnWebViewNavigated"
                Navigating="OnWebViewNavigating"/>

            <!-- Loading state -->
            <VerticalStackLayout
                IsVisible="{Binding IsBusy}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="20"
                Padding="40">

                <ActivityIndicator
                    IsRunning="{Binding IsBusy}"
                    Color="{StaticResource AppOrange}"
                    WidthRequest="52"
                    HeightRequest="52"
                    HorizontalOptions="Center"/>

                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label
                        Text="Opening book..."
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>
                    <Label
                        Text="This may take a moment"
                        FontFamily="OpenSansRegular"
                        FontSize="13"
                        TextColor="{StaticResource AppTextMuted}"
                        HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- Error state -->
            <VerticalStackLayout
                IsVisible="{Binding HasError}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="20"
                Padding="40">

                <Border
                    StrokeShape="RoundRectangle 20"
                    Stroke="#FFD0D0"
                    StrokeThickness="1.5"
                    HeightRequest="80"
                    WidthRequest="80"
                    HorizontalOptions="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFF5F5" Offset="0"/>
                            <GradientStop Color="#FFE5E5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label
                        Text="!"
                        FontFamily="OpenSansSemibold"
                        FontSize="38"
                        TextColor="{StaticResource AppError}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Unable to Load Book"
                        FontFamily="OpenSansSemibold"
                        FontSize="20"
                        TextColor="{StaticResource AppNavy}"
                        HorizontalTextAlignment="Center"/>
                    <Label
                        Text="{Binding ErrorMessage}"
                        FontFamily="OpenSansRegular"
                        FontSize="14"
                        TextColor="{StaticResource AppTextSecondary}"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="WordWrap"/>
                </VerticalStackLayout>

                <Button
                    Text="Go Back"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,4,0,0"
                    Command="{Binding GoBackCommand}"/>

            </VerticalStackLayout>

            <!-- ── Book switcher overlay ────────────────────────── -->
            <Grid x:Name="PanelOverlay" IsVisible="False">

                <!-- Dim backdrop — tap to close -->
                <BoxView BackgroundColor="#70000000">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOverlayTapped"/>
                    </BoxView.GestureRecognizers>
                </BoxView>

                <!-- Slide-up panel -->
                <Border
                    x:Name="SwitcherPanel"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource AppSurface}"
                    VerticalOptions="End"
                    Padding="0,0,0,0">

                    <Grid RowDefinitions="Auto,Auto,*">

                        <!-- Drag handle + header -->
                        <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="20,14,20,12">
                            <BoxView
                                WidthRequest="40"
                                HeightRequest="4"
                                CornerRadius="2"
                                BackgroundColor="{StaticResource AppDivider}"
                                HorizontalOptions="Center"
                                Margin="0,0,0,14"/>
                            <Label
                                Text="My Books"
                                FontFamily="OpenSansSemibold"
                                FontSize="17"
                                TextColor="{StaticResource AppNavy}"/>
                            <Label
                                Text="Tap a book to switch"
                                FontFamily="OpenSansRegular"
                                FontSize="12"
                                TextColor="{StaticResource AppTextMuted}"
                                Margin="0,2,0,0"/>
                        </VerticalStackLayout>

                        <!-- Divider -->
                        <BoxView
                            Grid.Row="1"
                            HeightRequest="1"
                            BackgroundColor="{StaticResource AppDivider}"
                            Margin="0,0,0,16"/>

                        <!-- Books horizontal list -->
                        <CollectionView
                            Grid.Row="2"
                            ItemsSource="{Binding LibraryItems}"
                            HeightRequest="220"
                            Margin="0,0,0,24">

                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout
                                    Orientation="Horizontal"
                                    ItemSpacing="12"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryBookItem">
                                    <Border
                                        WidthRequest="130"
                                        StrokeShape="RoundRectangle 14"
                                        StrokeThickness="2.5"
                                        Margin="0">

                                        <!-- Orange border for currently reading -->
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsCurrentBook}" Value="True">
                                                <Setter Property="Stroke" Value="{StaticResource AppOrange}"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsCurrentBook}" Value="False">
                                                <Setter Property="Stroke" Value="{StaticResource AppDivider}"/>
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SwitchBookCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>

                                        <Grid RowDefinitions="150,Auto">

                                            <!-- Cover image area -->
                                            <Grid Grid.Row="0">
                                                <Border
                                                    StrokeShape="RoundRectangle 12,12,0,0"
                                                    Stroke="Transparent">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#1A3660" Offset="0.0"/>
                                                            <GradientStop Color="#2E7BC4" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>

                                                <Image
                                                    Source="{Binding Book.ImageCoverUrl}"
                                                    Aspect="AspectFill"
                                                    IsVisible="{Binding Book.ImageCoverUrl, Converter={StaticResource NotNullConverter}}"/>

                                                <!-- Reading badge -->
                                                <Border
                                                    IsVisible="{Binding IsCurrentBook}"
                                                    BackgroundColor="{StaticResource AppOrange}"
                                                    StrokeShape="RoundRectangle 6"
                                                    Stroke="Transparent"
                                                    Padding="6,3"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="Start"
                                                    Margin="8,8,0,0">
                                                    <Label
                                                        Text="READING"
                                                        TextColor="White"
                                                        FontFamily="OpenSansSemibold"
                                                        FontSize="9"/>
                                                </Border>
                                            </Grid>

                                            <!-- Title -->
                                            <VerticalStackLayout
                                                Grid.Row="1"
                                                Padding="10,8,10,10"
                                                Spacing="2">
                                                <Label
                                                    Text="{Binding Book.Title}"
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="12"
                                                    TextColor="{StaticResource AppTextPrimary}"
                                                    MaxLines="2"
                                                    LineBreakMode="TailTruncation"/>
                                                <Label
                                                    Text="{Binding Book.Category}"
                                                    FontFamily="OpenSansRegular"
                                                    FontSize="10"
                                                    TextColor="{StaticResource AppTextMuted}"/>
                                            </VerticalStackLayout>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                            <CollectionView.Header>
                                <BoxView WidthRequest="20" HeightRequest="1" Color="Transparent"/>
                            </CollectionView.Header>

                            <CollectionView.Footer>
                                <BoxView WidthRequest="20" HeightRequest="1" Color="Transparent"/>
                            </CollectionView.Footer>

                        </CollectionView>

                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</ContentPage>
